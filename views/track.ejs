<section class="section container">
    <div class="text-center mb-2">
        <h1>Track Your Parcel</h1>
        <p class="text-muted">Real-time status updates for your delivery.</p>
    </div>

    <div class="max-w-md mx-auto">
        <div class="card shadow-md">
            <form id="trackForm" class="pure-form pure-form-stacked">
                <label>Tracking Code</label>
                <div class="flex gap-1">
                    <input type="text" id="trackCode" placeholder="GR-XXXX-XXXX" required class="pure-input-1">
                    <button type="submit" class="pure-button btn-primary">Track</button>
                </div>
            </form>
            
            <div id="trackResult" class="mt-2" style="display: none;">
                <div class="text-center mb-2">
                    <span class="badge badge-primary text-lg" id="statusBadge">Status</span>
                </div>
                <div class="timeline" id="timelineContainer">
                    <!-- Dynamic -->
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.timeline { display: flex; flex-direction: column; }
.timeline-item { display: flex; gap: 1rem; border-left: 2px solid var(--border); padding: 0 0 1.5rem 1.5rem; position: relative; }
.timeline-item::before { content: ''; position: absolute; left: -7px; top: 0; width: 12px; height: 12px; border-radius: 50%; background: var(--border); }
.timeline-item.active::before { background: var(--primary); }
.timeline-item.done::before { background: var(--success); }
</style>

<script>
document.getElementById('trackForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const code = document.getElementById('trackCode').value;
    const res = await fetch('/api/tracking/' + code);
    const data = await res.json();
    
    document.getElementById('trackResult').style.display = 'block';
    document.getElementById('statusBadge').innerText = data.status;
    
    const timeline = document.getElementById('timelineContainer');
    timeline.innerHTML = '';
    
    data.checkpoints.forEach((cp, i) => {
        const item = document.createElement('div');
        item.className = 'timeline-item ' + (i === 0 ? 'active' : 'done');
        item.innerHTML = `
            <div>
                <p class="font-bold">${cp.status} - ${cp.town}</p>
                <p class="text-xs text-muted">${cp.timestamp}</p>
                <p class="text-sm mt-1">${cp.notes}</p>
            </div>
        `;
        timeline.appendChild(item);
    });
});
</script>
