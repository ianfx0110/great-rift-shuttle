<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Book Trip' }) %>
</head>
<body class="bg-bg text-text font-sans antialiased">
    <%- include('partials/nav') %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="mb-12">
        <h1 class="text-3xl font-black text-primary mb-2 uppercase italic tracking-tight">Reservation Terminal</h1>
        <p class="text-xs text-gray-400 font-bold uppercase tracking-[3px]">Select your route and secure your seat.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Search Sidebar -->
        <aside class="lg:col-span-1">
          <div class="bg-card p-6 rounded-2xl border border-border shadow-sm sticky top-24">
            <h3 class="text-xs font-black uppercase tracking-widest text-accent mb-6 border-b border-border pb-4">Filter Logistics</h3>
            <form id="search-form" class="space-y-6">
              <div class="flex flex-col gap-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Departure</label>
                <select id="origin" class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none appearance-none">
                   <!-- Options loaded via JS -->
                </select>
              </div>
              <div class="flex flex-col gap-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Arrival Hub</label>
                <select id="destination" class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none appearance-none">
                   <!-- Options loaded via JS -->
                </select>
              </div>
              <div class="flex flex-col gap-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Target Date</label>
                <input type="date" id="date" class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none"/>
              </div>
              <button type="submit" class="w-full bg-primary text-white font-black py-4 rounded-xl hover:bg-blue-900 transition-all shadow-xl shadow-blue-900/10 text-xs uppercase tracking-widest">
                Refresh Manifest
              </button>
            </form>
          </div>
        </aside>

        <!-- Results Area -->
        <div class="lg:col-span-3">
          <div id="results-list" class="space-y-4">
             <!-- Loader -->
             <div class="text-center py-20 bg-card rounded-2xl border border-dashed border-border">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent mx-auto mb-4"></div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Scanning Dispatch Center...</p>
             </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Booking Modal -->
    <div id="booking-modal" class="fixed inset-0 bg-primary/40 backdrop-blur-sm z-[100] hidden items-center justify-center p-4">
       <div class="bg-card w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden border border-border">
          <div class="bg-primary p-8 text-white relative">
             <button id="close-modal" class="absolute top-6 right-6 text-white/50 hover:text-white"><i data-lucide="x"></i></button>
             <h2 class="text-2xl font-black italic uppercase tracking-tight mb-2">Finalize Booking</h2>
             <p class="text-[10px] font-black text-blue-300 uppercase tracking-widest" id="modal-route">...</p>
          </div>
          <div class="p-8">
             <div id="booking-step-1">
                <div id="seat-selection" class="mb-8">
                   <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Select Seat Position</p>
                   <div id="seats-grid" class="grid grid-cols-4 gap-3">
                      <!-- Seats generated via JS -->
                   </div>
                </div>
                <div class="space-y-4">
                   <div class="flex flex-col gap-1.5">
                      <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">M-Pesa Disburse Phone</label>
                      <input type="tel" id="pay-phone" placeholder="0711 222 333" class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none" />
                   </div>
                   <div class="flex justify-between items-center bg-accent/5 p-4 rounded-xl border border-accent/10">
                      <span class="text-xs font-black text-primary uppercase">Total Fare</span>
                      <span class="text-xl font-black text-accent italic" id="modal-fare">...</span>
                   </div>
                   <button id="show-confirmation" class="w-full bg-accent text-white font-black py-4 rounded-xl hover:bg-orange-600 transition-all shadow-xl shadow-orange-500/10 text-xs uppercase tracking-widest flex items-center justify-center">
                      Review Itinerary <i data-lucide="chevron-right" class="ml-2 w-4 h-4"></i>
                   </button>
                </div>
             </div>

             <div id="booking-step-2" class="hidden animate-in fade-in slide-in-from-right-4">
                <div class="bg-bg p-6 rounded-2xl border border-border mb-6 space-y-4">
                   <h4 class="text-xs font-black text-primary uppercase tracking-widest border-b border-border pb-3">Operational Summary</h4>
                   <div class="grid grid-cols-2 gap-4">
                      <div>
                         <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest">Route Network</p>
                         <p class="text-sm font-black text-primary italic uppercase" id="confirm-route">...</p>
                      </div>
                      <div>
                         <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest">Departure Time</p>
                         <p class="text-sm font-black text-primary italic uppercase" id="confirm-time">...</p>
                      </div>
                      <div>
                         <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest">Seat Allocation</p>
                         <p class="text-sm font-black text-primary italic uppercase" id="confirm-seat">...</p>
                      </div>
                      <div>
                         <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest">Settlement Amount</p>
                         <p class="text-sm font-black text-accent italic uppercase" id="confirm-fare">...</p>
                      </div>
                   </div>
                   <div class="pt-2">
                      <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest">Billing Provider</p>
                      <p class="text-sm font-black text-primary italic uppercase flex items-center"><i data-lucide="smartphone" class="w-3.5 h-3.5 mr-2"></i> M-PESA: <span id="confirm-phone">...</span></p>
                   </div>
                </div>
                
                <div class="flex gap-4">
                   <button id="back-to-seats" class="flex-1 bg-bg border border-border text-primary font-black py-4 rounded-xl hover:bg-slate-50 transition-all text-xs uppercase tracking-widest">
                      Modify
                   </button>
                   <button id="confirm-booking" class="flex-[2] bg-accent text-white font-black py-4 rounded-xl hover:bg-orange-600 transition-all shadow-xl shadow-orange-500/10 text-xs uppercase tracking-widest flex items-center justify-center">
                      Confirm & Pay <i data-lucide="shield-check" class="ml-2 w-4 h-4"></i>
                   </button>
                </div>
             </div>
          </div>
       </div>
    </div>

    <%- include('partials/footer') %>

    <script type="module">
      import { api, setupAuth } from '/src/main.js';
      setupAuth();

      const searchForm = document.getElementById('search-form');
      const resultsList = document.getElementById('results-list');
      const bookingModal = document.getElementById('booking-modal');
      const seatsGrid = document.getElementById('seats-grid');
      
      let selectedSchedule = null;
      let selectedSeat = null;

      // Load Hubs for dropdowns
      async function loadHubs() {
        const routes = await api.get('/api/routes');
        const origins = [...new Set(routes.map(r => r.origin))];
        const destinations = [...new Set(routes.map(r => r.destination))];

        const originSelect = document.getElementById('origin');
        const destSelect = document.getElementById('destination');

        originSelect.innerHTML = origins.map(o => `<option value="${o}">${o}</option>`).join('');
        destSelect.innerHTML = destinations.map(d => `<option value="${d}">${d}</option>`).join('');

        // Pre-fill from URL
        const params = new URLSearchParams(window.location.search);
        if (params.get('origin')) originSelect.value = params.get('origin');
        if (params.get('destination')) destSelect.value = params.get('destination');
        if (params.get('date')) document.getElementById('date').value = params.get('date');

        loadSchedules();
      }

      async function loadSchedules() {
        resultsList.innerHTML = `<div class="text-center py-20 bg-card rounded-2xl border border-dashed border-border"><div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent mx-auto mb-4"></div><p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Scanning Dispatch Center...</p></div>`;
        
        const origin = document.getElementById('origin').value;
        const destination = document.getElementById('destination').value;
        const date = document.getElementById('date').value;

        try {
          const schedules = await api.get(`/api/schedules?origin=${origin}&destination=${destination}&date=${date}`);
          
          if (schedules.length === 0) {
            resultsList.innerHTML = `<div class="bg-card p-12 rounded-2xl border border-border text-center"><p class="text-sm font-bold text-slate-400">No active manifests found for this route/date.</p></div>`;
            return;
          }

          resultsList.innerHTML = schedules.map(s => `
            <div class="bg-card p-6 rounded-2xl border border-border shadow-sm hover:shadow-md transition-all group">
              <div class="flex flex-col md:flex-row md:items-center justify-between">
                <div class="mb-4 md:mb-0">
                  <div class="flex items-center space-x-2 mb-2">
                    <span class="px-2 py-0.5 rounded-md bg-accent/20 text-accent text-[8px] font-black uppercase tracking-widest">${s.type}</span>
                    <span class="text-[8px] font-black text-slate-300 uppercase tracking-widest">Ref: #${s.id.toString().padStart(4,'0')}</span>
                  </div>
                  <h3 class="text-xl font-black italic uppercase tracking-tight text-primary flex items-center">
                    ${s.origin} <i data-lucide="arrow-right" class="w-4 h-4 mx-3 text-accent transition-transform group-hover:translate-x-1"></i> ${s.destination}
                  </h3>
                  <div class="flex items-center space-x-4 mt-3">
                     <div class="flex items-center text-xs font-bold text-slate-500">
                        <i data-lucide="clock" class="w-3.5 h-3.5 mr-1.5 text-accent"></i> 
                        ${new Date(s.departure_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
                     </div>
                     <div class="w-px h-3 bg-border"></div>
                     <div class="flex items-center text-xs font-bold text-slate-500">
                        <i data-lucide="bus" class="w-3.5 h-3.5 mr-1.5 text-accent"></i> 
                        ${s.number_plate}
                     </div>
                  </div>
                </div>
                <div class="flex items-center md:items-end flex-col">
                  <p class="text-2xl font-black text-primary italic mb-2 tracking-tighter uppercase">KES ${s.base_fare}</p>
                  <button onclick="openBookingModal(${s.id})" class="bg-primary text-white px-8 py-3 rounded-xl font-black text-[10px] uppercase tracking-widest shadow-lg shadow-blue-900/10 hover:bg-blue-900 transition-all">Secure Seat</button>
                </div>
              </div>
            </div>
          `).join('');
          lucide.createIcons();
        } catch (error) {
          resultsList.innerHTML = `<p class="text-red-500">Error: ${error.message}</p>`;
        }
      }

      window.openBookingModal = async (scheduleId) => {
        const schedules = await api.get(`/api/schedules`); // Filtered in real world
        selectedSchedule = schedules.find(s => s.id === scheduleId);
        
        document.getElementById('modal-route').textContent = `${selectedSchedule.origin} → ${selectedSchedule.destination}`;
        document.getElementById('modal-fare').textContent = `KES ${selectedSchedule.base_fare}`;
        
        // Reset steps
        document.getElementById('booking-step-1').classList.remove('hidden');
        document.getElementById('booking-step-2').classList.add('hidden');

        // Mock seats
        seatsGrid.innerHTML = Array.from({length: selectedSchedule.capacity}, (_, i) => `
          <button onclick="selectSeat(${i+1})" class="seat-btn w-full aspect-square border border-border rounded-lg text-[10px] font-black text-gray-400 hover:bg-accent/10 hover:border-accent transition-all flex items-center justify-center">${i+1}</button>
        `).join('');

        bookingModal.classList.remove('hidden');
        bookingModal.classList.add('flex');
        lucide.createIcons();
      };

      window.selectSeat = (num) => {
        document.querySelectorAll('.seat-btn').forEach(b => b.classList.remove('bg-accent', 'text-white', 'border-accent'));
        const btns = document.querySelectorAll('.seat-btn');
        if (btns[num-1]) {
           btns[num-1].classList.add('bg-accent', 'text-white', 'border-accent');
        }
        selectedSeat = num;
      };

      document.getElementById('show-confirmation').onclick = () => {
        if (!selectedSeat) return alert('Select a seat position');
        const phone = document.getElementById('pay-phone').value;
        if (!phone) return alert('Enter M-Pesa phone number');

        document.getElementById('confirm-route').textContent = `${selectedSchedule.origin} → ${selectedSchedule.destination}`;
        document.getElementById('confirm-time').textContent = new Date(selectedSchedule.departure_time).toLocaleString();
        document.getElementById('confirm-seat').textContent = `Seat #${selectedSeat}`;
        document.getElementById('confirm-fare').textContent = `KES ${selectedSchedule.base_fare}`;
        document.getElementById('confirm-phone').textContent = phone;

        document.getElementById('booking-step-1').classList.add('hidden');
        document.getElementById('booking-step-2').classList.remove('hidden');
        lucide.createIcons();
      };

      document.getElementById('back-to-seats').onclick = () => {
        document.getElementById('booking-step-1').classList.remove('hidden');
        document.getElementById('booking-step-2').classList.add('hidden');
      };

      document.getElementById('confirm-booking').onclick = async () => {
        if (!selectedSeat) return alert('Select a seat position');
        const phone = document.getElementById('pay-phone').value;
        if (!phone) return alert('Enter M-Pesa phone number');

        const btn = document.getElementById('confirm-booking');
        const user = JSON.parse(localStorage.getItem('user')) || {};

        try {
          btn.disabled = true;
          btn.innerHTML = `<div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></div> Processing...`;
          
          const res = await api.post('/api/bookings', {
            userId: user.id || null,
            scheduleId: selectedSchedule.id,
            seatNumber: selectedSeat,
            farePaid: selectedSchedule.base_fare,
            phone: phone,
            clientName: user.name || 'Guest',
            clientEmail: user.email || ''
          });
          
          document.getElementById('booking-modal').classList.add('hidden');
          alert('STK Push Sent! Reference: ' + res.reference + '\nCheck your phone to complete payment.');
          window.location.href = '/dashboard';
        } catch (error) {
          alert('Booking failed: ' + error.message);
        } finally {
          btn.disabled = false;
          btn.innerHTML = `Initiate Secure Payment <i data-lucide="shield-check" class="ml-2 w-4 h-4"></i>`;
          lucide.createIcons();
        }
      };

      document.getElementById('close-modal').onclick = () => {
        bookingModal.classList.add('hidden');
      };

      searchForm.onsubmit = (e) => {
        e.preventDefault();
        loadSchedules();
      };

      loadHubs();
    </script>
</body>
</html>
