<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'New Route' }) %>
</head>
<body class="bg-bg text-text font-sans antialiased">
    <%- include('partials/nav') %>

    <main class="max-w-xl mx-auto px-4 py-20">
      <div class="bg-card p-10 rounded-[40px] border border-border shadow-2xl">
        <h1 class="text-3xl font-black text-primary mb-2 uppercase italic tracking-tight">Expand Matrix</h1>
        <p class="text-xs text-slate-400 font-bold uppercase tracking-[3px] mb-10">Establish a new logistics Corridor.</p>

        <form action="/newroute" method="POST" class="space-y-6">
          <div class="space-y-2">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Origin Terminal</label>
            <input type="text" name="origin" required placeholder="e.g. NAIROBI" class="w-full bg-bg border border-border rounded-2xl px-6 py-4 text-sm font-black uppercase tracking-widest focus:ring-2 focus:ring-accent outline-none" />
          </div>

          <div class="space-y-2">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Destination Hub</label>
            <input type="text" name="destination" required placeholder="e.g. ELDORET" class="w-full bg-bg border border-border rounded-2xl px-6 py-4 text-sm font-black uppercase tracking-widest focus:ring-2 focus:ring-accent outline-none" />
          </div>

          <div class="grid grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Distance (KM)</label>
              <input type="number" name="distance" required placeholder="320" class="w-full bg-bg border border-border rounded-2xl px-6 py-4 text-sm font-black focus:ring-2 focus:ring-accent outline-none" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Est. Duration</label>
              <input type="text" name="duration" required placeholder="6h 30m" class="w-full bg-bg border border-border rounded-2xl px-6 py-4 text-sm font-black focus:ring-2 focus:ring-accent outline-none" />
            </div>
          </div>

          <button type="submit" class="w-full bg-primary text-white font-black py-5 rounded-2xl hover:bg-blue-900 transition-all shadow-xl shadow-blue-900/10 text-xs uppercase tracking-widest mt-4">
            Verify & Establish Link
          </button>
        </form>
      </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
