<section class="section container">
    <div class="flex justify-between items-center mb-2">
        <h1>My Travel Dashboard</h1>
        <a href="/auth/logout" class="pure-button btn-outline">Log Out</a>
    </div>

    <div class="pure-g">
        <div class="pure-u-1 pure-u-md-1-3 mb-2">
            <div class="card text-center">
                <div class="user-pill mx-auto mb-1" style="width: 80px; height: 80px; font-size: 2rem;">
                    <%= user.first_name ? user.first_name[0] : 'U' %>
                </div>
                <h3><%= user.first_name %> <%= user.last_name %></h3>
                <p class="text-muted"><%= user.email %></p>
                <p class="badge badge-info mt-1">PASSENGER</p>
            </div>
        </div>
        
        <div class="pure-u-1 pure-u-md-2-3">
            <div class="card">
                <h3>My Bookings</h3>
                <div class="mt-1">
                    <% if (bookings.length === 0) { %>
                        <p class="text-muted">No travel bookings found.</p>
                        <a href="/book" class="pure-button btn-primary mt-1">Book Your First Trip</a>
                    <% } else { %>
                        <table class="pure-table w-full">
                            <thead>
                                <tr>
                                    <th>Trip</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% bookings.forEach(b => { %>
                                    <tr>
                                        <td><%= b.origin %> &rarr; <%= b.destination %></td>
                                        <td><%= new Date(b.departure_time).toLocaleDateString() %></td>
                                        <td><%= b.payment_status %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>
