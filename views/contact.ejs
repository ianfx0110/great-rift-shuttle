<section class="section container">
    <div class="pure-g">
        <div class="pure-u-1 pure-u-md-1-2 mb-2">
            <h1>Contact Us</h1>
            <p class="text-muted mb-2">Have a question or need assistance? Our team is here to help you 24/7.</p>
            
            <div class="mb-2">
                <h4>Main Office</h4>
                <p>Nairobi CBD, River Road</p>
                <p>Phone: +254 700 000000</p>
                <p>Email: support@greatriftshuttle.co.ke</p>
            </div>
            
            <div class="mb-2">
                <h4>Hours of Operation</h4>
                <p>Monday - Sunday: 05:00 AM - 10:00 PM</p>
                <p>Parcel Office Open 24 Hours</p>
            </div>
            
            <div class="social-links large">
                <a href="#"><i class="ti ti-brand-facebook"></i></a>
                <a href="#"><i class="ti ti-brand-twitter"></i></a>
                <a href="#"><i class="ti ti-brand-whatsapp"></i></a>
            </div>
        </div>
        
        <div class="pure-u-1 pure-u-md-1-2">
            <div class="card shadow-lg">
                <h4 class="mb-1">Send a Message</h4>
                <form id="contactForm" class="pure-form pure-form-stacked">
                    <label>Full Name</label>
                    <input type="text" id="c_name" name="name" required class="pure-input-1">
                    
                    <label>Email Address</label>
                    <input type="email" id="c_email" name="email" required class="pure-input-1">
                    
                    <label>Phone Number</label>
                    <input type="tel" id="c_phone" name="phone" class="pure-input-1">
                    
                    <label>Subject</label>
                    <select id="c_subject" name="subject" class="pure-input-1">
                        <option>General Enquiry</option>
                        <option>Booking Issue</option>
                        <option>Parcel Tracking</option>
                        <option>Cargo Quotation</option>
                        <option>Feedback</option>
                    </select>
                    
                    <label>Message</label>
                    <textarea id="c_message" name="message" rows="5" required class="pure-input-1"></textarea>
                    
                    <button type="submit" class="pure-button btn-primary w-full mt-1">Send via WhatsApp</button>
                </form>
            </div>
        </div>
    </div>
</section>

<script>
    document.getElementById('contactForm')?.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const name = document.getElementById('c_name').value;
        const email = document.getElementById('c_email').value;
        const phone = document.getElementById('c_phone').value;
        const subject = document.getElementById('c_subject').value;
        const message = document.getElementById('c_message').value;

        let whatsappMsg = `*NEW CONTACT MESSAGE*\n\n`;
        whatsappMsg += `*From:* ${name}\n`;
        whatsappMsg += `*Email:* ${email}\n`;
        whatsappMsg += `*Phone:* ${phone}\n`;
        whatsappMsg += `*Subject:* ${subject}\n\n`;
        whatsappMsg += `*Message:*\n${message}\n`;

        const encoded = encodeURIComponent(whatsappMsg);
        const whatsappUrl = `https://wa.me/254115481162?text=${encoded}`;
        
        window.open(whatsappUrl, '_blank');
    });
</script>
