<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Great Rift Shuttle | <%= (typeof title !== 'undefined') ? title : "Passenger, Parcel & Cargo" %></title>
    
    <!-- Pure CSS via CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/purecss@3.0.0/build/pure-min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/purecss@3.0.0/build/grids-responsive-min.css">
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400..700;1,9..40,400..700&family=Syne:wght@400..800&display=swap" rel="stylesheet">
    
    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
    
    <!-- Custom CSS -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/nav.css">

    <script>
        // Init theme
        (function() {
            const theme = localStorage.getItem('theme') || 'system';
            if (theme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
            } else if (theme === 'light') {
                document.documentElement.setAttribute('data-theme', 'light');
            } else {
                // System default - CSS media query handles this, but we clear data-theme
                document.documentElement.removeAttribute('data-theme');
            }
        })();
    </script>
    <% if (typeof extraCSS !== 'undefined') { %>
        <% extraCSS.forEach(function(css) { %>
            <link rel="stylesheet" href="/css/<%= css %>.css">
        <% }); %>
    <% } %>
</head>
<body>
