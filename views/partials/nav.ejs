<header class="site-header">
    <nav class="nav-container">
        <div class="nav-inner">
            <div class="nav-logo">
                <a href="/">
                    <img src="/logo.svg" alt="Great Rift Shuttle" height="50">
                </a>
            </div>
            
            <button class="nav-hamburger" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <div class="nav-menu" id="navMenu">
                <ul class="nav-links list-unstyled">
                    <li><a href="/" class="nav-link <%= path === '/' ? 'active' : '' %>">Home</a></li>
                    
                    <% if (user && user.role === 'admin') { %>
                        <li><a href="/admin/dashboard" class="nav-link">Dashboard</a></li>
                        <li><a href="/admin/drivers" class="nav-link">Drivers</a></li>
                        <li><a href="/admin/trips" class="nav-link">Control Center</a></li>
                    <% } else if (user && user.role === 'driver') { %>
                        <li><a href="/driver/dashboard" class="nav-link">My Trips</a></li>
                    <% } else { %>
                        <li><a href="/routes" class="nav-link">Routes</a></li>
                        <li><a href="/book" class="nav-link">Book</a></li>
                        <li><a href="/parcel" class="nav-link">Parcel</a></li>
                    <% } %>

                    <li><a href="/track" class="nav-link">Track</a></li>
                    <li><a href="/about" class="nav-link">About</a></li>
                </ul>

                <div class="nav-actions">
                    <button id="themeToggle" class="theme-toggle" aria-label="Toggle theme">
                        <i class="ti ti-sun icon-sun"></i>
                        <i class="ti ti-moon icon-moon"></i>
                    </button>
                    
                    <% if (typeof user !== 'undefined' && user) { %>
                        <a href="/<%= user.role %>/dashboard" class="user-pill" title="<%= user.first_name %>">
                            <%= (user.first_name ? user.first_name[0] : 'S') %>
                        </a>
                        <a href="/auth/logout" class="pure-button btn-outline">Out</a>
                    <% } else { %>
                        <a href="/book" class="pure-button btn-primary hide-mobile">Book Now</a>
                        <a href="/auth" class="text-sm text-muted hover-primary">Staff Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>
    <div class="nav-overlay" id="navOverlay"></div>
</header>
