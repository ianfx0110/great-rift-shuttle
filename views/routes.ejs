<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Route Matrix' }) %>
</head>
<body class="bg-bg text-text font-sans antialiased">
    <%- include('partials/nav') %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="mb-12">
        <span class="text-accent font-black text-[10px] uppercase tracking-[3px] mb-2 block">Network Status: Online</span>
        <h1 class="text-3xl font-black text-primary mb-2 uppercase italic tracking-tight">Logistics Corridors</h1>
        <p class="text-xs text-gray-400 font-bold uppercase tracking-[3px]">Our active connection nodes across the Rift Valley.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
         <!-- Existing Featured Hubs ... (keeping for aesthetic) -->
         <div class="bg-card p-8 rounded-3xl border border-border shadow-sm flex flex-col justify-between group hover:border-accent transition-all">
            <div>
               <h3 class="text-xl font-black text-primary uppercase italic mb-4">Central Hub <br/><span class="text-accent underline">Nairobi</span></h3>
               <p class="text-xs text-slate-400 font-bold leading-relaxed">The heart of Great Rift Shuttle operations. Daily departures to all western circuit destinations from our CBD terminal.</p>
            </div>
            <div class="mt-8 flex justify-between items-end border-t border-border pt-6">
               <div>
                  <p class="text-[8px] font-black text-slate-300 uppercase tracking-widest mb-1">Active Slots</p>
                  <p class="text-sm font-black text-primary uppercase">12 Trips Daily</p>
               </div>
               <i data-lucide="map-pin" class="text-accent w-5 h-5 opacity-20 group-hover:opacity-100 transition-opacity"></i>
            </div>
         </div>

         <div class="bg-card p-8 rounded-3xl border border-border shadow-sm flex flex-col justify-between group hover:border-accent transition-all">
            <div>
               <h3 class="text-xl font-black text-primary uppercase italic mb-4">Western Node <br/><span class="text-accent underline">Kisumu</span></h3>
               <p class="text-xs text-slate-400 font-bold leading-relaxed">Connecting the lake region with premium shuttle services. Dedicated parcel hub and night travel security.</p>
            </div>
            <div class="mt-8 flex justify-between items-end border-t border-border pt-6">
               <div>
                  <p class="text-[8px] font-black text-slate-300 uppercase tracking-widest mb-1">Active Slots</p>
                  <p class="text-sm font-black text-primary uppercase">8 Trips Daily</p>
               </div>
               <i data-lucide="map-pin" class="text-accent w-5 h-5 opacity-20 group-hover:opacity-100 transition-opacity"></i>
            </div>
         </div>

         <div class="bg-card p-8 rounded-3xl border border-border shadow-sm flex flex-col justify-between group hover:border-accent transition-all">
            <div>
               <h3 class="text-xl font-black text-primary uppercase italic mb-4">Valley Node <br/><span class="text-accent underline">Nakuru</span></h3>
               <p class="text-xs text-slate-400 font-bold leading-relaxed">Quick connects and parcel collection point. Ideally positioned for intermediate trade between Nairobi and deep western routes.</p>
            </div>
            <div class="mt-8 flex justify-between items-end border-t border-border pt-6">
               <div>
                  <p class="text-[8px] font-black text-slate-300 uppercase tracking-widest mb-1">Active Slots</p>
                  <p class="text-sm font-black text-primary uppercase">15 Trips Daily</p>
               </div>
               <i data-lucide="map-pin" class="text-accent w-5 h-5 opacity-20 group-hover:opacity-100 transition-opacity"></i>
            </div>
         </div>
      </div>

      <!-- Dynamic Route Matrix (Student Style Table) -->
      <div class="mb-12">
        <h2 class="text-2xl font-black text-primary mb-6 uppercase italic">Complete Route Manifest</h2>
        <div class="bg-card rounded-3xl border border-border shadow-xl overflow-hidden">
          <table class="w-full text-left">
            <thead class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] bg-bg border-b border-border">
              <tr>
                <th class="px-8 py-5">Origin Hub</th>
                <th class="px-8 py-5">Destination Hub</th>
                <th class="px-8 py-5">Distance</th>
                <th class="px-8 py-5">Est. Time</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              <% routes.forEach(route => { %>
                <tr class="hover:bg-bg/50 transition-colors group">
                  <td class="px-8 py-6">
                    <div class="flex items-center space-x-3">
                      <div class="w-2 h-2 rounded-full bg-accent group-hover:scale-125 transition-transform"></div>
                      <span class="text-sm font-black uppercase text-primary tracking-tight"><%= route.origin %></span>
                    </div>
                  </td>
                  <td class="px-8 py-6">
                    <span class="text-sm font-black uppercase text-primary tracking-tight"><%= route.destination %></span>
                  </td>
                  <td class="px-8 py-6">
                    <span class="text-xs font-bold text-slate-500"><%= route.distance_km %> KM</span>
                  </td>
                  <td class="px-8 py-6">
                    <span class="text-xs font-black text-accent italic"><%= route.estimated_duration %></span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="mt-16 bg-primary p-12 rounded-[40px] text-white relative overflow-hidden">
         <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-96 h-96 bg-blue-800 rounded-full blur-3xl opacity-50"></div>
         <div class="relative z-10 lg:grid lg:grid-cols-2 gap-12 items-center">
            <div>
               <h2 class="text-4xl font-black italic uppercase leading-[1.1] mb-6">Need a <br/><span class="text-accent underline">Chartered</span> <br/>Route?</h2>
               <p class="text-blue-200 text-sm font-medium leading-relaxed mb-8 max-w-md">We offer dedicated group charters for corporate events, funerals, and community travel. Customize your departure and arrival terminals within our matrix.</p>
               <a href="/contact" class="bg-accent text-white px-8 py-4 rounded-xl font-black text-xs uppercase tracking-widest shadow-xl shadow-orange-500/10 hover:bg-orange-600 transition-all inline-flex items-center">
                  Request Quote <i data-lucide="arrow-right" class="ml-2 w-4 h-4"></i>
               </a>
            </div>
            <div class="hidden lg:block bg-blue-800/50 border border-blue-700/50 p-8 rounded-3xl backdrop-blur-sm">
               <div class="space-y-4">
                  <div class="flex justify-between items-center p-3 border-b border-blue-700">
                     <span class="text-[10px] font-black uppercase text-blue-400">Hub 1</span>
                     <span class="text-xs font-bold">Nairobi Terminal</span>
                  </div>
                  <div class="flex justify-between items-center p-3 border-b border-blue-700">
                     <span class="text-[10px] font-black uppercase text-blue-400">Hub 2</span>
                     <span class="text-xs font-bold">Eldoret Hub</span>
                  </div>
                  <div class="flex justify-between items-center p-3">
                     <span class="text-[10px] font-black uppercase text-blue-400">Hub 3</span>
                     <span class="text-xs font-bold">Kisumu Lakefront</span>
                  </div>
               </div>
            </div>
         </div>
      </div>
    </main>

    <%- include('partials/footer') %>
</body>
</html>
