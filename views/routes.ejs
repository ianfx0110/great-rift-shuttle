<section class="section container">
    <div class="text-center mb-2">
        <h1>Our Travel Routes</h1>
        <p class="text-muted">Explore our extensive network of routes across the Rift and beyond.</p>
    </div>

    <div class="pure-g">
        <% routes.forEach(r => { %>
            <div class="pure-u-1 pure-u-md-1-2 mb-2">
                <div class="card route-full-card">
                    <div class="flex justify-between items-center mb-1">
                        <h3><%= r.origin_name %> &rarr; <%= r.dest_name %></h3>
                        <span class="badge badge-success">Active</span>
                    </div>
                    <div class="pure-g mt-1">
                        <div class="pure-u-1-3">
                            <p class="text-xs text-muted">DISTANCE</p>
                            <p class="font-bold"><%= r.distance_km %> KM</p>
                        </div>
                        <div class="pure-u-1-3">
                            <p class="text-xs text-muted">DURATION</p>
                            <p class="font-bold">~<%= Math.floor(r.distance_km / 60) + 1 %> HRS</p>
                        </div>
                        <div class="pure-u-1-3">
                            <p class="text-xs text-muted">FARE</p>
                            <p class="font-bold text-primary">KES <%= r.base_fare %></p>
                        </div>
                    </div>
                    <div class="mt-2">
                        <details class="route-stops">
                            <summary>View Stations & Stops</summary>
                            <ul class="mt-1">
                                <li><%= r.origin_name %> Main Office (Start)</li>
                                <li>Intermediate Stop 1</li>
                                <li><%= r.dest_name %> Station (End)</li>
                            </ul>
                        </details>
                    </div>
                    <div class="mt-2">
                        <a href="/book?from=<%= r.origin_id %>&to=<%= r.destination_id %>" class="pure-button btn-primary">Book This Route</a>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</section>
