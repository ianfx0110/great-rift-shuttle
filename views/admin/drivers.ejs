<section class="section container">
    <div class="flex justify-between items-center mb-2">
        <h1>Driver Management</h1>
        <button class="pure-button btn-primary" onclick="toggleRegForm()">+ Register Driver</button>
    </div>

    <!-- Registration Form -->
    <div id="regForm" class="card mb-2" style="display: none;">
        <h3 class="mb-1">Register New Driver</h3>
        <form action="/admin/drivers/register" method="POST" class="pure-form pure-form-stacked">
            <div class="pure-g">
                <div class="pure-u-1 pure-u-md-1-2">
                    <label>First Name</label>
                    <input type="text" name="first_name" required class="pure-input-1">
                </div>
                <div class="pure-u-1 pure-u-md-1-2">
                    <label>Last Name</label>
                    <input type="text" name="last_name" required class="pure-input-1">
                </div>
                <div class="pure-u-1 pure-u-md-1-2">
                    <label>Username</label>
                    <input type="text" name="username" required class="pure-input-1">
                </div>
                <div class="pure-u-1 pure-u-md-1-2">
                    <label>Password</label>
                    <input type="password" name="password" required class="pure-input-1">
                </div>
                <div class="pure-u-1 pure-u-md-1-2">
                    <label>Email</label>
                    <input type="email" name="email" required class="pure-input-1">
                </div>
                <div class="pure-u-1 pure-u-md-1-2">
                    <label>Phone</label>
                    <input type="tel" name="phone" required class="pure-input-1">
                </div>
                <div class="pure-u-1 pure-u-md-1-3">
                    <label>ID Number</label>
                    <input type="text" name="id_number" required class="pure-input-1">
                </div>
                <div class="pure-u-1 pure-u-md-1-3">
                    <label>License Number</label>
                    <input type="text" name="license_number" required class="pure-input-1">
                </div>
                <div class="pure-u-1 pure-u-md-1-3">
                    <label>License Expiry</label>
                    <input type="date" name="license_expiry_date" required class="pure-input-1">
                </div>
            </div>
            <div class="mt-1">
                <button type="submit" class="pure-button btn-primary">Save Driver</button>
                <button type="button" class="pure-button btn-outline" onclick="toggleRegForm()">Cancel</button>
            </div>
        </form>
    </div>

    <div class="card">
        <table class="pure-table pure-table-horizontal w-full">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>License</th>
                    <th>Rating</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <% drivers.forEach(d => { %>
                    <tr>
                        <td><%= d.first_name %> <%= d.last_name %></td>
                        <td><%= d.email %></td>
                        <td><%= d.license_number %></td>
                        <td><%= d.rating_cache %> ⭐</td>
                        <td><span class="badge badge-success"><%= d.status %></span></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</section>

<script>
    function toggleRegForm() {
        const form = document.getElementById('regForm');
        form.style.display = form.style.display === 'none' ? 'block' : 'none';
        form.scrollIntoView({ behavior: 'smooth' });
    }
</script>
