<section class="section container">
    <div class="flex justify-between items-center mb-2">
        <h1>Admin Control Center</h1>
        <div class="badge badge-primary">ROOT ACCESS</div>
    </div>

    <div class="pure-g mb-2">
        <div class="pure-u-1 pure-u-md-1-4">
            <div class="card text-center">
                <i class="ti ti-bus text-4xl text-primary"></i>
                <h4 class="mt-1">Trips</h4>
                <p class="text-2xl font-bold"><%= stats.trips %></p>
            </div>
        </div>
        <div class="pure-u-1 pure-u-md-1-4">
            <div class="card text-center">
                <i class="ti ti-users text-4xl text-primary"></i>
                <h4 class="mt-1">Drivers</h4>
                <p class="text-2xl font-bold"><%= stats.drivers %></p>
            </div>
        </div>
        <div class="pure-u-1 pure-u-md-1-4">
            <div class="card text-center">
                <i class="ti ti-ticket text-4xl text-primary"></i>
                <h4 class="mt-1">Bookings</h4>
                <p class="text-2xl font-bold"><%= stats.bookings %></p>
            </div>
        </div>
        <div class="pure-u-1 pure-u-md-1-4">
            <div class="card text-center">
                <i class="ti ti-package text-4xl text-primary"></i>
                <h4 class="mt-1">Parcels</h4>
                <p class="text-2xl font-bold"><%= stats.parcels %></p>
            </div>
        </div>
    </div>

    <div class="pure-g">
        <div class="pure-u-1 pure-u-md-1-2">
            <div class="card h-full">
                <h3 class="mb-1">Recent Activity</h3>
                <div class="mt-1">
                    <% recentTrips.forEach(t => { %>
                        <div class="flex justify-between p-1 border-bottom">
                            <span><%= t.origin %> &rarr; <%= t.destination %></span>
                            <span class="text-muted"><%= new Date(t.departure_time).toLocaleDateString() %></span>
                        </div>
                    <% }) %>
                </div>
                <a href="/admin/trips" class="pure-button btn-outline mt-2 w-full">Manage All Trips</a>
            </div>
        </div>
        
        <div class="pure-u-1 pure-u-md-1-2">
            <div class="card h-full">
                <h3 class="mb-1">Quick Actions</h3>
                <div class="flex flex-col gap-1 mt-1">
                    <a href="/admin/drivers" class="pure-button btn-primary">Register New Driver</a>
                    <a href="/admin/routes" class="pure-button btn-accent">Add Travel Route</a>
                    <a href="/admin/reports" class="pure-button btn-outline">Financial Reports</a>
                </div>
            </div>
        </div>
    </div>
</section>
