<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Fleet Control' }) %>
</head>
<body class="bg-slate-50 text-slate-900 font-sans antialiased">
    <div class="flex min-h-screen">
      <!-- Admin Sidebar -->
      <aside class="w-64 bg-primary text-white flex flex-col hidden lg:flex">
        <div class="p-6 border-b border-blue-900/50">
          <div class="flex items-center space-x-2">
            <div class="bg-accent p-1 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-white w-4 h-4">
                <path d="M4 18h16"></path>
                <circle cx="18" cy="18" r="2"></circle>
                <circle cx="6" cy="18" r="2"></circle>
                <path d="M19 18V9a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v9"></path>
                <path d="M16 9v4"></path>
                <path d="M3 13h16"></path>
                <path d="M8 9h4"></path>
              </svg>
            </div>
            <span class="text-sm font-black tracking-tight uppercase">Great Rift <span class="text-accent italic">Fleet</span></span>
          </div>
        </div>
        <nav class="flex-1 p-4 space-y-1">
          <a href="javascript:void(0)" onclick="switchTab('dashboard')" class="flex items-center p-3 rounded-lg bg-blue-800 text-white font-bold text-xs uppercase tracking-widest transition-all">
            <i data-lucide="layout-dashboard" class="w-4 h-4 mr-3 text-accent"></i> Core Ops
          </a>
          <a href="javascript:void(0)" onclick="switchTab('fleet')" class="flex items-center p-3 rounded-lg hover:bg-blue-800 text-blue-200 font-bold text-xs uppercase tracking-widest transition-colors">
            <i data-lucide="bus" class="w-4 h-4 mr-3"></i> Fleet Registry
          </a>
          <a href="javascript:void(0)" onclick="switchTab('drivers')" class="flex items-center p-3 rounded-lg hover:bg-blue-800 text-blue-200 font-bold text-xs uppercase tracking-widest transition-colors">
            <i data-lucide="users" class="w-4 h-4 mr-3"></i> Service Crew
          </a>
          <a href="javascript:void(0)" onclick="switchTab('routes')" class="flex items-center p-3 rounded-lg hover:bg-blue-800 text-blue-200 font-bold text-xs uppercase tracking-widest transition-colors">
            <i data-lucide="map" class="w-4 h-4 mr-3 text-accent"></i> Route Matrix
          </a>
          <a href="#" class="flex items-center p-3 rounded-lg hover:bg-blue-800 text-blue-200 font-bold text-xs uppercase tracking-widest transition-colors">
            <i data-lucide="bar-chart-3" class="w-4 h-4 mr-3"></i> Revenue Intel
          </a>
        </nav>
        <div class="p-6 border-t border-blue-900/50">
          <button id="logout-btn" class="text-blue-300 font-black flex items-center text-[10px] uppercase tracking-[2px] w-full hover:text-red-400 transition-colors">
            <i data-lucide="log-out" class="w-3.5 h-3.5 mr-3"></i> Exit System
          </button>
        </div>
      </aside>

      <!-- Main Workspace -->
      <main class="flex-1 overflow-y-auto">
        <header class="h-16 bg-card border-b border-border px-8 flex items-center justify-between sticky top-0 z-30 transition-colors duration-300">
          <div class="lg:hidden">
             <i data-lucide="menu" class="text-primary w-6 h-6"></i>
          </div>
          <h2 class="text-xs font-black uppercase tracking-widest text-slate-400 italic">Command Center <i data-lucide="chevron-right" class="inline w-3 h-3 mx-1"></i> Global Overview</h2>
          <div class="flex items-center space-x-6">
             <button id="admin-theme-toggle" class="p-2 rounded-lg bg-bg border border-border text-primary hover:text-accent transition-colors">
               <i data-lucide="sun" id="admin-sun-icon" class="w-4 h-4 hidden"></i>
               <i data-lucide="moon" id="admin-moon-icon" class="w-4 h-4 hidden"></i>
             </button>
             <div class="w-8 h-8 rounded-full bg-accent flex items-center justify-center text-white font-black text-xs shadow-lg shadow-accent/20">A</div>
          </div>
        </header>

        <div class="p-8">
          <!-- Dashboard Section -->
          <div id="dashboard-section">
            <!-- Stats Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
               <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm overflow-hidden relative group">
                  <div class="absolute right-0 bottom-0 opacity-5 group-hover:scale-150 transition-transform duration-700">
                     <i data-lucide="banknote" class="w-24 h-24 text-primary"></i>
                  </div>
                  <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Gross Intake</p>
                  <h3 id="stat-revenue" class="text-2xl font-black text-primary italic leading-none mb-2">KES <%= stats.totalRevenue.toLocaleString() %></h3>
                  <span class="text-[8px] font-black uppercase text-success">+12.4% vs Last Cycle</span>
               </div>
               <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                  <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Flight Capacity</p>
                  <h3 id="stat-bookings" class="text-2xl font-black text-primary italic leading-none mb-2"><%= stats.totalBookings %></h3>
                  <span class="text-[8px] font-black uppercase text-accent">Total Reservations</span>
               </div>
               <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                  <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Active Fleet</p>
                  <h3 id="stat-vehicles" class="text-2xl font-black text-primary italic leading-none mb-2">...</h3>
                  <span class="text-[8px] font-black uppercase text-blue-400">Operational Units</span>
               </div>
               <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
                  <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Human Capital</p>
                  <h3 id="stat-users" class="text-2xl font-black text-primary italic leading-none mb-2"><%= stats.totalUsers %></h3>
                  <span class="text-[8px] font-black uppercase text-slate-400">Registered Accounts</span>
               </div>
            </div>

            <!-- Bottom Grid -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
               <!-- Real-time Activity -->
               <div class="lg:col-span-2 bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                  <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                     <h4 class="text-[10px] font-black text-primary uppercase tracking-widest italic">Live Operations Manifest</h4>
                     <span class="bg-green-50 text-success border border-green-100 text-[8px] font-black uppercase px-2 py-0.5 rounded flex items-center">
                        <span class="w-1.5 h-1.5 bg-success rounded-full animate-pulse mr-2"></span> System Online
                     </span>
                  </div>
                  <div class="overflow-x-auto">
                     <table class="w-full text-left">
                        <thead class="text-[8px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-50 bg-slate-50/20">
                           <tr>
                              <th class="px-6 py-4">Consignor/Traveler</th>
                              <th class="px-6 py-4">Reference</th>
                              <th class="px-6 py-4">Route Network</th>
                              <th class="px-6 py-4 text-right">Settlement</th>
                           </tr>
                        </thead>
                        <tbody id="recent-bookings" class="divide-y divide-slate-50 text-xs font-bold">
                           <!-- Loaded via API -->
                        </tbody>
                     </table>
                  </div>
               </div>

               <!-- Control Panel -->
               <div class="lg:col-span-1 space-y-6">
                  <div class="bg-white p-8 rounded-2xl border border-slate-200 shadow-sm">
                     <h4 class="text-[10px] font-black uppercase tracking-widest text-accent mb-6">Quick Directives</h4>
                     <div class="grid grid-cols-1 gap-3">
                        <button onclick="switchTab('fleet')" class="w-full text-left p-4 rounded-xl bg-slate-50 font-black text-[10px] uppercase tracking-widest text-primary border border-slate-100 flex items-center group">
                           <i data-lucide="plus" class="w-4 h-4 mr-3 text-accent group-hover:rotate-90 transition-transform"></i> New Fleet Unit
                        </button>
                        <button onclick="switchTab('routes')" class="w-full text-left p-4 rounded-xl bg-slate-50 font-black text-[10px] uppercase tracking-widest text-primary border border-slate-100 flex items-center group">
                           <i data-lucide="map-pin" class="w-4 h-4 mr-3 text-accent group-hover:scale-110 transition-transform"></i> Define New Route
                        </button>
                        <button onclick="switchTab('drivers')" class="w-full text-left p-4 rounded-xl bg-slate-50 font-black text-[10px] uppercase tracking-widest text-primary border border-slate-100 flex items-center group">
                           <i data-lucide="users" class="w-4 h-4 mr-3 text-accent group-hover:scale-110 transition-transform"></i> Onboard Driver
                        </button>
                     </div>
                  </div>

                  <div class="bg-blue-900 p-8 rounded-2xl text-white shadow-xl relative overflow-hidden">
                     <div class="absolute -right-4 -top-4 w-24 h-24 bg-accent/20 rounded-full blur-2xl"></div>
                     <h4 class="text-[10px] font-black uppercase tracking-widest text-accent mb-4">M-Pesa Ledger</h4>
                     <p class="text-xs text-blue-200 font-bold mb-4">Total secure digital payments processed this session.</p>
                     <p class="text-3xl font-black italic tracking-tighter uppercase" id="ledger-total">KES 0</p>
                  </div>
               </div>
            </div>
          </div>

          <!-- Routes Management Section -->
          <div id="routes-section" class="hidden">
            <div class="flex justify-between items-center mb-8">
              <div>
                <h3 class="text-2xl font-black text-primary uppercase italic">Route Matrix</h3>
                <p class="text-slate-400 text-[10px] font-black uppercase tracking-widest">Connect urban hubs and rural terminals</p>
              </div>
              <button onclick="toggleRouteModal()" class="bg-accent text-white px-6 py-3 rounded-xl font-black uppercase tracking-widest text-xs shadow-lg hover:bg-orange-600 transition-all flex items-center">
                <i data-lucide="plus" class="w-4 h-4 mr-2"></i> New Route
              </button>
            </div>

            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
              <table class="w-full text-left">
                <thead class="text-[8px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-50 bg-slate-50/20">
                  <tr>
                    <th class="px-6 py-4">Origin Terminal</th>
                    <th class="px-6 py-4">Destination Terminal</th>
                    <th class="px-6 py-4">Distance (KM)</th>
                    <th class="px-6 py-4">Est. Duration</th>
                    <th class="px-6 py-4 text-right">Actions</th>
                  </tr>
                </thead>
                <tbody id="routes-list" class="divide-y divide-slate-50 text-xs font-bold">
                  <% routes.forEach(r => { %>
                    <tr class="hover:bg-slate-50 transition-colors">
                      <td class="px-6 py-4 uppercase"><%= r.origin %></td>
                      <td class="px-6 py-4 uppercase"><%= r.destination %></td>
                      <td class="px-6 py-4"><%= r.distance_km %> KM</td>
                      <td class="px-6 py-4 italic text-slate-400"><%= r.estimated_duration %></td>
                      <td class="px-6 py-4 text-right">
                        <button onclick="deleteRoute(<%= r.id %>)" class="text-red-400 hover:text-red-600 transition-colors">
                          <i data-lucide="trash-2" class="w-4 h-4"></i>
                        </button>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Fleet Management Section -->
          <div id="fleet-section" class="hidden">
            <div class="flex justify-between items-center mb-8">
              <div>
                <h3 class="text-2xl font-black text-primary uppercase italic">Fleet Registry</h3>
                <p class="text-slate-400 text-[10px] font-black uppercase tracking-widest">Manage your operational hardware</p>
              </div>
              <button class="bg-primary text-white px-6 py-3 rounded-xl font-black uppercase tracking-widest text-xs shadow-lg hover:bg-blue-900 transition-all flex items-center">
                <i data-lucide="plus" class="w-4 h-4 mr-2"></i> Commission Van
              </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="fleet-grid">
               <!-- To be loaded via API -->
               <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm animate-pulse">
                  <div class="h-4 bg-slate-100 rounded w-1/2 mb-4"></div>
                  <div class="h-8 bg-slate-100 rounded mb-4"></div>
                  <div class="h-4 bg-slate-100 rounded w-3/4"></div>
               </div>
            </div>
          </div>

          <!-- Driver Management Section -->
          <div id="drivers-section" class="hidden">
            <div class="flex justify-between items-center mb-8">
              <div>
                <h3 class="text-2xl font-black text-primary uppercase italic">Service Crew</h3>
                <p class="text-slate-400 text-[10px] font-black uppercase tracking-widest">Manage your logistics specialists</p>
              </div>
              <button onclick="toggleDriverModal()" class="bg-primary text-white px-6 py-3 rounded-xl font-black uppercase tracking-widest text-xs shadow-lg hover:bg-blue-900 transition-all flex items-center">
                <i data-lucide="plus" class="w-4 h-4 mr-2"></i> Onboard Driver
              </button>
            </div>

            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
               <table class="w-full text-left">
                 <thead class="text-[8px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-50 bg-slate-50/20">
                   <tr>
                     <th class="px-6 py-4">Specialist</th>
                     <th class="px-6 py-4">License/ID</th>
                     <th class="px-6 py-4">Contact</th>
                     <th class="px-6 py-4">Exp. Date</th>
                     <th class="px-6 py-4 text-right">Actions</th>
                   </tr>
                 </thead>
                 <tbody id="drivers-list" class="divide-y divide-slate-50 text-xs font-bold">
                   <% drivers.forEach(d => { %>
                     <tr class="hover:bg-slate-50 transition-colors">
                       <td class="px-6 py-4">
                         <div class="flex items-center space-x-3">
                           <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-primary font-black text-[10px]">
                             <%= d.first_name[0] %><%= d.last_name[0] %>
                           </div>
                           <div>
                             <p class="uppercase"><%= d.first_name %> <%= d.last_name %></p>
                             <span class="text-[8px] text-slate-400 uppercase">Status: <%= d.status %></span>
                           </div>
                         </div>
                       </td>
                       <td class="px-6 py-4">
                         <p class="uppercase text-[10px] text-accent"><%= d.license_number %></p>
                         <p class="text-[9px] text-slate-400">ID: <%= d.id_number %></p>
                       </td>
                       <td class="px-6 py-4">
                         <p><%= d.phone_number %></p>
                       </td>
                       <td class="px-6 py-4 italic text-slate-400">
                         <%= new Date(d.license_expiry_date).toLocaleDateString() %>
                       </td>
                       <td class="px-6 py-4 text-right">
                         <button onclick="deleteDriver(<%= d.id %>)" class="text-red-400 hover:text-red-600 transition-colors">
                           <i data-lucide="trash-2" class="w-4 h-4"></i>
                         </button>
                       </td>
                     </tr>
                   <% }) %>
                 </tbody>
               </table>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Driver Modal -->
    <div id="driver-modal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
      <div class="bg-white w-full max-w-lg rounded-3xl p-8 shadow-2xl">
        <div class="flex justify-between items-center mb-6">
          <h4 class="text-lg font-black text-primary uppercase italic">Specialist Onboarding</h4>
          <button onclick="toggleDriverModal()" class="text-slate-400 hover:text-primary"><i data-lucide="x"></i></button>
        </div>
        <form id="driver-form" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-2">First Name</label>
              <input type="text" name="firstName" required placeholder="e.g. John" class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 font-bold text-sm focus:ring-2 focus:ring-accent outline-none">
            </div>
            <div>
              <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-2">Last Name</label>
              <input type="text" name="lastName" required placeholder="e.g. Doe" class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 font-bold text-sm focus:ring-2 focus:ring-accent outline-none">
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-2">National ID</label>
              <input type="text" name="idNumber" required placeholder="12345678" class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 font-bold text-sm focus:ring-2 focus:ring-accent outline-none">
            </div>
            <div>
              <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-2">Phone Number</label>
              <input type="tel" name="phoneNumber" required placeholder="0712345678" class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 font-bold text-sm focus:ring-2 focus:ring-accent outline-none">
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-2">License Number</label>
              <input type="text" name="licenseNumber" required placeholder="DL-XXXXX" class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 font-bold text-sm focus:ring-2 focus:ring-accent outline-none">
            </div>
            <div>
              <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-2">License Expiry</label>
              <input type="date" name="licenseExpiry" required class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 font-bold text-sm focus:ring-2 focus:ring-accent outline-none">
            </div>
          </div>
          <button type="submit" class="w-full bg-primary text-white py-5 rounded-2xl font-black uppercase tracking-[0.2em] text-xs shadow-xl hover:bg-blue-900 transition-all">Authorize Onboarding</button>
        </form>
      </div>
    </div>

    <!-- Route Modal -->
    <div id="route-modal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
      <div class="bg-white w-full max-w-md rounded-3xl p-8 shadow-2xl">
        <div class="flex justify-between items-center mb-6">
          <h4 class="text-lg font-black text-primary uppercase italic">Add Digital Link</h4>
          <button onclick="toggleRouteModal()" class="text-slate-400 hover:text-primary"><i data-lucide="x"></i></button>
        </div>
        <form id="route-form" class="space-y-4">
          <div>
            <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-2">Origin Terminal</label>
            <input type="text" name="origin" required placeholder="e.g. NAKURU" class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 font-bold text-sm focus:ring-2 focus:ring-accent outline-none uppercase placeholder:lowercase">
          </div>
          <div>
            <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-2">Destination Terminal</label>
            <input type="text" name="destination" required placeholder="e.g. ELDORET" class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 font-bold text-sm focus:ring-2 focus:ring-accent outline-none uppercase placeholder:lowercase">
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-2">Distance (KM)</label>
              <input type="number" name="distance_km" required placeholder="150" class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 font-bold text-sm focus:ring-2 focus:ring-accent outline-none">
            </div>
            <div>
              <label class="text-[9px] font-black text-slate-400 uppercase tracking-widest block mb-2">Est. Hours</label>
              <input type="text" name="duration" required placeholder="e.g. 3h 30m" class="w-full bg-slate-50 border border-slate-100 rounded-xl p-4 font-bold text-sm focus:ring-2 focus:ring-accent outline-none">
            </div>
          </div>
          <button type="submit" class="w-full bg-primary text-white py-5 rounded-2xl font-black uppercase tracking-[0.2em] text-xs shadow-xl hover:bg-blue-900 transition-all">Establish Link</button>
        </form>
      </div>
    </div>
        </div>
      </main>
    </div>

    <script type="module">
      import { api, setupAuth } from '/src/main.js';
      setupAuth();

      const user = JSON.parse(localStorage.getItem('user'));
      if (!user || user.role !== 'admin') {
        window.location.href = '/login';
      }

      async function loadAdminStats() {
        // Redundant with SSR but kept for live updates if needed
        lucide.createIcons();
      }

      async function loadRoutes() {
        // Redundant with SSR
        lucide.createIcons();
      }

      window.switchTab = (tab) => {
        document.getElementById('dashboard-section').classList.add('hidden');
        document.getElementById('routes-section').classList.add('hidden');
        document.getElementById('fleet-section').classList.add('hidden');
        document.getElementById('drivers-section').classList.add('hidden');
        
        document.querySelectorAll('aside nav a').forEach(a => {
          a.classList.remove('bg-blue-800');
          a.classList.add('text-blue-200');
        });

        // Find match in sidebar or update icons
        const sidebarLinks = document.querySelectorAll('aside nav a');
        if (tab === 'dashboard') sidebarLinks[0].classList.add('bg-blue-800');
        if (tab === 'fleet') sidebarLinks[1].classList.add('bg-blue-800');
        if (tab === 'drivers') sidebarLinks[2].classList.add('bg-blue-800');
        if (tab === 'routes') sidebarLinks[3].classList.add('bg-blue-800');

        if (tab === 'dashboard') {
          document.getElementById('dashboard-section').classList.remove('hidden');
          loadAdminStats();
        } else if (tab === 'routes') {
          document.getElementById('routes-section').classList.remove('hidden');
          loadRoutes();
        } else if (tab === 'fleet') {
          document.getElementById('fleet-section').classList.remove('hidden');
          loadFleet();
        } else if (tab === 'drivers') {
          document.getElementById('drivers-section').classList.remove('hidden');
          loadDrivers();
        }
      };

      async function loadDrivers() {
        try {
          const drivers = await api.get('/api/admin/drivers');
          const list = document.getElementById('drivers-list');
          list.innerHTML = drivers.map(d => `
            <tr class="hover:bg-slate-50 transition-colors">
               <td class="px-6 py-4">
                 <div class="flex items-center space-x-3">
                   <div class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center text-primary font-black text-[10px]">
                     ${d.first_name[0]}${d.last_name[0]}
                   </div>
                   <div>
                     <p class="uppercase">${d.first_name} ${d.last_name}</p>
                     <span class="text-[8px] text-slate-400 uppercase">Status: ${d.status}</span>
                   </div>
                 </div>
               </td>
               <td class="px-6 py-4">
                 <p class="uppercase text-[10px] text-accent">${d.license_number}</p>
                 <p class="text-[9px] text-slate-400">ID: ${d.id_number}</p>
               </td>
               <td class="px-6 py-4">
                 <p>${d.phone_number}</p>
               </td>
               <td class="px-6 py-4 italic text-slate-400">
                 ${new Date(d.license_expiry_date).toLocaleDateString()}
               </td>
               <td class="px-6 py-4 text-right">
                 <button onclick="deleteDriver(${d.id})" class="text-red-400 hover:text-red-600 transition-colors">
                   <i data-lucide="trash-2" class="w-4 h-4"></i>
                 </button>
               </td>
             </tr>
          `).join('');
          lucide.createIcons();
        } catch (error) {
          console.error(error);
        }
      }

      window.toggleDriverModal = () => {
        document.getElementById('driver-modal').classList.toggle('hidden');
      };

      window.deleteDriver = async (id) => {
        if (!confirm('Authorize termination of this specialist contract?')) return;
        try {
          await api.delete(`/api/admin/drivers/${id}`);
          loadDrivers();
        } catch (error) {
          alert('Failed to delete driver');
        }
      };

      document.getElementById('driver-form').onsubmit = async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        try {
          await api.post('/api/admin/drivers', data);
          toggleDriverModal();
          loadDrivers();
          e.target.reset();
        } catch (error) {
          alert('Onboarding failed');
        }
      };

      async function loadFleet() {
        try {
          const stats = await api.get('/api/admin/stats');
          // In a real app we'd have a separate fleet endpoint
          // For now, let's use some dummy logic to show the grid
          const grid = document.getElementById('fleet-grid');
          grid.innerHTML = Array(stats.activeBuses).fill(0).map((_, i) => `
            <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden group">
               <div class="absolute -right-4 -top-4 opacity-10 group-hover:scale-125 transition-transform">
                  <i data-lucide="bus" class="w-20 h-20 text-primary"></i>
               </div>
               <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Unit ID: GR-${100 + i}</p>
               <h4 class="text-xl font-black text-primary italic mb-2">KCT 45${i}Z</h4>
               <div class="flex items-center space-x-2">
                 <span class="w-2 h-2 rounded-full bg-success"></span>
                 <span class="text-[10px] font-bold text-slate-500 uppercase">Operational</span>
               </div>
            </div>
          `).join('');
          lucide.createIcons();
        } catch (error) {
          console.error(error);
        }
      }

      window.toggleRouteModal = () => {
        const modal = document.getElementById('route-modal');
        modal.classList.toggle('hidden');
      };

      window.deleteRoute = async (id) => {
        if (!confirm('Are you sure you want to terminate this route network link?')) return;
        try {
          await api.delete(`/api/admin/routes/${id}`);
          loadRoutes();
        } catch (error) {
          alert('Operation failed');
        }
      };

      document.getElementById('route-form').onsubmit = async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = {
          origin: formData.get('origin'),
          destination: formData.get('destination'),
          distance_km: parseInt(formData.get('distance_km')),
          estimated_duration: formData.get('duration')
        };

        try {
          await api.post('/api/admin/routes', data);
          toggleRouteModal();
          loadRoutes();
          e.target.reset();
        } catch (error) {
          alert('Failed to establish link');
        }
      };

      function setupAdminTheme() {
        const sunIcon = document.getElementById('admin-sun-icon');
        const moonIcon = document.getElementById('admin-moon-icon');
        const themeToggle = document.getElementById('admin-theme-toggle');

        function updateIcons(isDark) {
          if (sunIcon && moonIcon) {
            if (isDark) {
              sunIcon.classList.remove('hidden');
              moonIcon.classList.add('hidden');
            } else {
              sunIcon.classList.add('hidden');
              moonIcon.classList.remove('hidden');
            }
          }
        }

        const isDark = document.documentElement.classList.contains('dark');
        updateIcons(isDark);

        const toggle = () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          updateIcons(isDark);
          lucide.createIcons();
        };

        if (themeToggle) themeToggle.onclick = toggle;
      }

      setupAdminTheme();
      loadAdminStats();

      document.getElementById('logout-btn').onclick = () => {
        localStorage.removeItem('user');
        window.location.href = '/login';
      };

      lucide.createIcons();
    </script>
</body>
</html>
