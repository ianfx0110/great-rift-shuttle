<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Signup' }) %>
</head>
<body class="bg-bg min-h-screen flex items-center justify-center p-4 font-sans antialiased text-text">
    <div class="max-w-4xl w-full grid grid-cols-1 md:grid-cols-2 bg-card rounded-3xl shadow-2xl overflow-hidden border border-border transition-colors duration-300">
      <!-- Info Side -->
      <div class="bg-accent p-12 text-white hidden md:flex flex-col justify-between relative overflow-hidden">
        <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-64 h-64 bg-white/20 rounded-full blur-3xl opacity-30"></div>
        <div class="relative z-10">
          <a href="/" class="flex items-center space-x-2 mb-12 group">
            <div class="bg-primary p-1.5 rounded-lg group-hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-white">
                  <path d="M4 18h16"></path>
                  <circle cx="18" cy="18" r="2"></circle>
                  <circle cx="6" cy="18" r="2"></circle>
                  <path d="M19 18V9a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v9"></path>
                  <path d="M16 9v4"></path>
                  <path d="M3 13h16"></path>
                  <path d="M8 9h4"></path>
                </svg>
            </div>
            <span class="text-xl font-black italic tracking-tighter uppercase">Great Rift<span class="text-primary underline decoration-2 underline-offset-4 decoration-2">Sacco</span></span>
          </a>
          <h2 class="text-4xl font-black leading-[1.1] mb-6">Join the <br/>Great Rift <br/><span class="text-primary italic">Community.</span></h2>
          <p class="text-white/80 text-sm font-medium leading-relaxed">Unlock premium booking, freight management, and real-time transit alerts across East Africa's busiest corridors.</p>
        </div>
        <div class="relative z-10 bg-white/10 border border-white/20 p-4 rounded-xl">
           <p class="text-[10px] font-black uppercase tracking-widest text-white/60 mb-2">Member Benefit</p>
           <p class="text-xs font-bold leading-relaxed">Instant manifests, priority parcel collection, and digital ticket management from any device.</p>
        </div>
      </div>

      <!-- Form Side -->
      <div class="p-8 md:p-12 self-center">
        <span class="text-accent font-black text-[10px] uppercase tracking-[3px] mb-2 block">Registration</span>
        <h3 class="text-2xl font-black text-primary mb-1">Create your free account in seconds</h3>
        <p class="text-xs text-slate-400 font-bold mb-8 uppercase tracking-tight">Join Kenya's elite transport network.</p>
        
        <form id="signup-form" class="space-y-4">
          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Full Name</label>
            <input type="text" id="reg-name" required placeholder="Noah Thompson" class="w-full bg-bg border border-border rounded-xl px-4 py-3.5 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none transition-all"/>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Email ID</label>
            <input type="email" id="reg-email" required placeholder="noah@example.com" class="w-full bg-bg border border-border rounded-xl px-4 py-3.5 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none transition-all"/>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Phone Number</label>
            <p class="text-[8px] font-bold text-slate-400 uppercase mb-1">07 12 345 678</p>
            <input type="tel" id="reg-phone" required placeholder="0712 345 678" class="w-full bg-bg border border-border rounded-xl px-4 py-3.5 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none transition-all"/>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Password</label>
            <p class="text-[8px] font-bold text-slate-400 uppercase mb-1">Create a password</p>
            <input type="password" id="reg-password" required placeholder="••••••••" class="w-full bg-bg border border-border rounded-xl px-4 py-3.5 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none transition-all"/>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Confirm Password</label>
            <p class="text-[8px] font-bold text-slate-400 uppercase mb-1">Confirm your password</p>
            <input type="password" id="reg-confirm" required placeholder="••••••••" class="w-full bg-bg border border-border rounded-xl px-4 py-3.5 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none transition-all"/>
          </div>

          <button type="submit" class="w-full bg-primary text-white font-black py-4 rounded-xl hover:bg-blue-900 transition-all shadow-xl shadow-blue-900/10 mt-6 text-sm uppercase tracking-widest italic translate-y-0 active:translate-y-1">
            Create Account
          </button>
        </form>
        
        <p class="mt-8 text-center text-[10px] font-black uppercase tracking-widest text-slate-400">
          Already have an account? <a href="/login" class="text-accent hover:underline italic">Sign In</a>
        </p>
      </div>
    </div>

    <script type="module">
      import { api } from '/src/main.js';
      lucide.createIcons();

      document.getElementById('signup-form').onsubmit = async (e) => {
        e.preventDefault();
        try {
          const res = await api.post('/api/auth/register', {
            name: document.getElementById('reg-name').value,
            phone: document.getElementById('reg-phone').value,
            email: document.getElementById('reg-email').value,
            password: document.getElementById('reg-password').value
          });
          localStorage.setItem('user', JSON.stringify(res.user));
          window.location.href = '/dashboard';
        } catch (error) {
          alert('Enrollment failed: ' + error.message);
        }
      };
    </script>
</body>
</html>
