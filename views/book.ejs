<section class="section container">
    <div class="text-center mb-2">
        <h1>Book Your Trip</h1>
        <p class="text-muted">Travel comfortably and safely with Great Rift Shuttle.</p>
    </div>

    <div class="step-bar" id="stepBar">
        <div class="step active" data-step="1">
            <div class="step-num">1</div>
            <div class="step-label">Route</div>
        </div>
        <div class="step-line"></div>
        <div class="step" data-step="2">
            <div class="step-num">2</div>
            <div class="step-label">Select Trip</div>
        </div>
        <div class="step-line"></div>
        <div class="step" data-step="3">
            <div class="step-num">3</div>
            <div class="step-label">Select Seat</div>
        </div>
        <div class="step-line"></div>
        <div class="step" data-step="4">
            <div class="step-num">4</div>
            <div class="step-label">Details</div>
        </div>
        <div class="step-line"></div>
        <div class="step" data-step="5">
            <div class="step-num">5</div>
            <div class="step-label">Payment</div>
        </div>
        <div class="step-line"></div>
        <div class="step" data-step="6">
            <div class="step-num">6</div>
            <div class="step-label">Ticket</div>
        </div>
    </div>

    <div id="step-container" class="card shadow-md">
        <!-- Step 1 Form -->
        <div id="step-1" class="step-content active">
            <form id="searchForm" class="pure-form pure-form-stacked">
                <div class="pure-g">
                    <div class="pure-u-1 pure-u-md-1-2 mb-1">
                        <label>From</label>
                        <select name="from" required class="pure-input-1">
                            <option value="">Select Origin</option>
                            <% towns.forEach(t => { %>
                                <option value="<%= t.name %>"><%= t.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="pure-u-1 pure-u-md-1-2 mb-1">
                        <label>To</label>
                        <select name="to" required class="pure-input-1">
                            <option value="">Select Destination</option>
                            <% towns.forEach(t => { %>
                                <option value="<%= t.name %>"><%= t.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="pure-u-1 pure-u-md-1-2 mb-1">
                        <label>Travel Date</label>
                        <input type="date" name="date" required class="pure-input-1" min="<%= new Date().toISOString().split('T')[0] %>">
                    </div>
                    <div class="pure-u-1 pure-u-md-1-2 mb-1">
                        <label>Passengers</label>
                        <input type="number" name="passengers" value="1" min="1" max="5" class="pure-input-1">
                    </div>
                </div>
                <div class="mt-2 text-right">
                    <button type="submit" class="pure-button btn-primary">Find Trips &rarr;</button>
                </div>
            </form>
        </div>

        <!-- Placeholder for dynamic steps -->
        <div id="dynamic-steps"></div>
    </div>
</section>

<style>
.step-content { display: none; }
.step-content.active { display: block; animation: fadeIn .3s ease; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

.seat-grid {
    display: grid;
    grid-template-columns: repeat(4, 40px);
    gap: 10px;
    justify-content: center;
    margin: 2rem 0;
}
.seat-item {
    width: 40px;
    height: 40px;
    background: #e0e0e0;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
}
.seat-item.selected { background: var(--accent); }
.seat-item.taken { background: #ccc; cursor: not-allowed; opacity: 0.5; }
.aisle { grid-column: 3; background: transparent; cursor: default; }
</style>
