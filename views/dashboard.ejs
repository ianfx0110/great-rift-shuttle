<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Passenger Dashboard' }) %>
</head>
<body class="bg-bg text-text font-sans antialiased">
    <%- include('partials/nav') %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Profile Card -->
         <div class="lg:col-span-1">
          <div class="bg-card rounded-3xl border border-border shadow-xl overflow-hidden sticky top-24">
            <div class="bg-primary h-24 relative">
               <div class="absolute -bottom-10 left-1/2 -translate-x-1/2 w-20 h-20 bg-accent rounded-2xl border-4 border-card flex items-center justify-center shadow-lg">
                  <i data-lucide="user" class="text-white w-10 h-10"></i>
               </div>
            </div>
            <div class="pt-14 pb-8 px-6 text-center">
               <h2 id="user-name" class="text-xl font-black italic text-primary">...</h2>
               <p id="user-email" class="text-xs text-slate-400 font-bold mb-6">...</p>
               <span id="user-role" class="px-3 py-1 rounded-full bg-blue-500/10 text-primary border border-blue-500/20 text-[8px] font-black uppercase tracking-widest">...</span>
            </div>
            <div class="border-t border-border p-6 space-y-3">
               <button class="w-full text-left p-3 rounded-xl bg-bg text-primary text-[10px] font-black uppercase tracking-widest border border-border">Booking History</button>
               <button class="w-full text-left p-3 rounded-xl hover:bg-bg text-slate-400 text-[10px] font-black uppercase tracking-widest transition-all">Profile Settings</button>
               <button id="db-logout-btn" class="w-full text-left p-3 rounded-xl hover:bg-red-500/10 text-red-500 text-[10px] font-black uppercase tracking-widest transition-all">Exit Terminal</button>
            </div>
          </div>
        </div>

        <!-- History Area -->
        <div class="lg:col-span-3">
          <div class="mb-8 flex justify-between items-end">
            <div>
              <h1 class="text-3xl font-black text-primary mb-1 uppercase italic tracking-tight">Recent Activity</h1>
              <p class="text-xs text-slate-400 font-bold uppercase tracking-[3px]">Your travel and logistics records.</p>
            </div>
          </div>

          <div id="booking-history" class="space-y-4">
             <!-- Loader -->
             <div class="text-center py-20 bg-card rounded-3xl border border-dashed border-border">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent mx-auto mb-4"></div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Compiling Records...</p>
             </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('partials/footer') %>

    <script type="module">
      import { api, setupAuth } from '/src/main.js';
      setupAuth();

      const user = JSON.parse(localStorage.getItem('user'));
      if (!user) {
        window.location.href = '/login';
      } else {
        // Role-based routing
        if (user.role === 'admin') {
          window.location.href = '/admin';
        } else if (user.role === 'driver') {
          window.location.href = '/driver_dashboard';
        } else if (user.role === 'clerk') {
          window.location.href = '/clerk_dashboard';
        }
        
        document.getElementById('user-name').textContent = user.name;
        document.getElementById('user-email').textContent = user.email;
        document.getElementById('user-role').textContent = user.role.toUpperCase();
        loadHistory();
      }

      async function loadHistory() {
        try {
          const bookings = await api.get(`/api/user/bookings?userId=${user.id}`);
          const list = document.getElementById('booking-history');
          
          if (bookings.length === 0) {
            list.innerHTML = `<div class="bg-card p-12 rounded-3xl border border-border text-center"><p class="text-sm font-bold text-slate-400 italic">No historical records found for this terminal ID.</p></div>`;
            return;
          }

          list.innerHTML = bookings.map(b => `
            <div class="bg-card p-6 rounded-2xl border border-border shadow-sm hover:shadow-md transition-all group">
              <div class="flex flex-col md:flex-row md:items-center justify-between">
                <div>
                  <div class="flex items-center space-x-2 mb-2">
                    <span class="px-2 py-0.5 rounded-md bg-blue-500/10 text-primary text-[8px] font-black uppercase tracking-widest">Confirmed Trip</span>
                    <span class="text-[8px] font-black text-slate-300 uppercase tracking-widest">ID: ${b.booking_reference}</span>
                  </div>
                  <h3 class="text-lg font-black italic uppercase tracking-tight text-primary flex items-center">
                    ${b.origin} <i data-lucide="arrow-right" class="w-3.5 h-3.5 mx-3 text-accent"></i> ${b.destination}
                  </h3>
                  <p class="text-xs font-bold text-slate-400 mt-1 uppercase tracking-tighter">${new Date(b.departure_time).toLocaleString('en-GB')}</p>
                </div>
                <div class="mt-4 md:mt-0 flex items-center md:items-end flex-col">
                  <span class="text-xs font-black text-primary italic mb-2">Seat #${b.seat_number}</span>
                  <div class="px-4 py-1 rounded-full bg-green-500/10 text-success border border-green-500/20 text-[8px] font-black uppercase tracking-widest">${b.payment_status}</div>
                </div>
              </div>
            </div>
          `).join('');
          lucide.createIcons();
        } catch (error) {
          console.error(error);
        }
      }

      document.getElementById('db-logout-btn').onclick = () => {
        localStorage.removeItem('user');
        window.location.href = '/login';
      };
    </script>
</body>
</html>
