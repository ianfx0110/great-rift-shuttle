<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Office Clerk Terminal' }) %>
</head>
<body class="bg-slate-50 text-slate-900 font-sans antialiased">
    <!-- Navbar -->
    <nav class="bg-white border-b border-slate-200 fixed w-full z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center space-x-2">
            <a href="/" class="flex items-center space-x-2">
              <div class="bg-primary p-1.5 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-white w-5 h-5">
                  <path d="M4 18h16"></path>
                  <circle cx="18" cy="18" r="2"></circle>
                  <circle cx="6" cy="18" r="2"></circle>
                  <path d="M19 18V9a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v9"></path>
                  <path d="M16 9v4"></path>
                  <path d="M3 13h16"></path>
                  <path d="M8 9h4"></path>
                </svg>
              </div>
              <span class="text-xl font-black italic tracking-tight uppercase text-primary">Office <span class="text-accent underline underline-offset-4 decoration-2">Terminal</span></span>
            </a>
          </div>
          <div class="flex items-center space-x-6 text-[10px] font-black uppercase tracking-widest text-slate-400">
             <span id="terminal-location" class="flex items-center"><i data-lucide="map-pin" class="w-3.5 h-3.5 mr-2 text-accent"></i> Nairobi Hub</span>
             <button id="logout-btn" class="text-red-500 hover:text-red-700">Logout</button>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
        <!-- Dashboard Summary -->
        <div class="lg:col-span-1 space-y-6">
           <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
              <h2 id="clerk-name" class="text-lg font-black text-primary mb-1">...</h2>
              <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-6 border-b border-slate-100 pb-4">Station Duty Clerk</p>
              
              <div class="grid grid-cols-2 gap-4">
                 <div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
                    <p class="text-[8px] font-black uppercase text-slate-400 mb-1">Parcels Today</p>
                    <p class="text-xl font-black text-primary italic">24</p>
                 </div>
                 <div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
                    <p class="text-[8px] font-black uppercase text-slate-400 mb-1">Incoming</p>
                    <p class="text-xl font-black text-accent italic">12</p>
                 </div>
              </div>
           </div>

           <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden group">
              <div class="absolute -right-4 -top-4 w-20 h-20 bg-accent/10 rounded-full group-hover:scale-150 transition-transform duration-700 opacity-50"></div>
              <h4 class="text-[10px] font-black uppercase tracking-widest text-accent mb-4">Quick Actions</h4>
              <nav class="space-y-2 relative z-10">
                 <a href="/parcel" class="flex items-center p-3 rounded-xl bg-primary text-white text-[10px] font-black uppercase tracking-widest shadow-lg shadow-blue-900/10 hover:bg-blue-900 transition-all">
                    <i data-lucide="package-plus" class="w-4 h-4 mr-3"></i> New Shipment
                 </a>
                 <a href="/booking" class="flex items-center p-3 rounded-xl bg-white border border-slate-200 text-primary text-[10px] font-black uppercase tracking-widest hover:bg-slate-50 transition-all">
                    <i data-lucide="ticket" class="w-4 h-4 mr-3 text-accent"></i> Counter Booking
                 </a>
                 <button class="w-full flex items-center p-3 rounded-xl bg-white border border-slate-200 text-primary text-[10px] font-black uppercase tracking-widest hover:bg-slate-50 transition-all text-left">
                    <i data-lucide="clipboard-list" class="w-4 h-4 mr-3 text-success"></i> Today's Manifest
                 </button>
              </nav>
           </div>
        </div>

        <!-- Working Area -->
        <div class="lg:col-span-3 space-y-6">
           <!-- Search Section -->
           <div class="bg-white p-6 rounded-2xl border border-slate-200 shadow-sm">
              <h3 class="text-xs font-black uppercase tracking-widest text-slate-400 mb-4 flex items-center">
                 <i data-lucide="search" class="w-3.5 h-3.5 mr-2 text-accent"></i> Logistics Lookup
              </h3>
              <div class="flex gap-4">
                 <input type="text" placeholder="Enter Tracking Number or Manifest Ticket ID..." class="flex-1 bg-slate-50 border border-slate-200 px-4 py-3 rounded-xl text-xs font-bold focus:outline-none focus:ring-2 focus:ring-primary/20">
                 <button class="bg-accent text-white px-8 py-3 rounded-xl font-black text-xs uppercase tracking-widest shadow-lg shadow-orange-500/10 hover:bg-orange-600 transition-all">Search</button>
              </div>
           </div>

           <!-- Tables Grid -->
           <div class="grid grid-cols-1 gap-6">
              <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                 <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                    <h4 class="text-xs font-black text-primary uppercase tracking-tight">Recent Station Shipments</h4>
                    <span class="text-[9px] font-black text-accent uppercase bg-accent/10 px-2 py-0.5 rounded border border-accent/20">Live Sync</span>
                 </div>
                 <div class="overflow-x-auto">
                    <table class="w-full text-left">
                       <thead class="text-[9px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-50">
                          <tr>
                             <th class="px-6 py-4">Consignment</th>
                             <th class="px-6 py-4">Route</th>
                             <th class="px-6 py-4">Price</th>
                             <th class="px-6 py-4">State</th>
                          </tr>
                       </thead>
                       <tbody class="divide-y divide-slate-50 text-xs font-bold" id="recent-shipments">
                          <tr>
                             <td class="px-6 py-4">
                                <p class="text-primary font-black italic">TRK-GRS001</p>
                                <p class="text-[9px] text-slate-400 uppercase">Documents • 2.5kg</p>
                             </td>
                             <td class="px-6 py-4 uppercase tracking-tighter">Nairobi <i data-lucide="arrow-right" class="inline w-3 h-3 mx-1 text-accent"></i> Kisumu</td>
                             <td class="px-6 py-4 text-primary font-black">KES 450</td>
                             <td class="px-6 py-4">
                                <span class="bg-blue-50 text-primary border border-blue-100 px-2 py-0.5 rounded text-[10px] font-black italic">Processed</span>
                             </td>
                          </tr>
                       </tbody>
                    </table>
                 </div>
              </div>
           </div>
        </div>
      </div>
    </main>

    <script type="module">
      import { api, setupAuth } from '/src/main.js';
      setupAuth();

      const user = JSON.parse(localStorage.getItem('user'));
      if (!user || user.role !== 'clerk') {
        window.location.href = '/login';
      } else {
        document.getElementById('clerk-name').textContent = user.name;
        document.getElementById('terminal-location').innerHTML = `<i data-lucide="map-pin" class="w-3.5 h-3.5 mr-2 text-accent"></i> Station: ${user.phone ? 'Remote' : 'Main Hub'}`;
      }

      document.getElementById('logout-btn').onclick = () => {
        localStorage.removeItem('user');
        window.location.href = '/login';
      };
      
      lucide.createIcons();
    </script>
</body>
</html>
