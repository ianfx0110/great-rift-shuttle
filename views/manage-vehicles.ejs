<% const title = 'Manage Vehicles - Great Rift Shuttle'; %>
<%- include('dashboard-header') %>

<div class="dashboard-wrapper">
  <%- include('dashboard-aside', { activePage: 'vehicles' }) %>

  <!-- Main Content -->
  <main class="dashboard-main">
    <div class="dashboard-header">
      <div>
        <h1>Manage Vehicles</h1>
        <% if(addSuccess){ %>
          <div class="alert alert-success" style="color: green; background-color: aliceblue;">
            Vehicle added successfully!
          </div>
        <% } %>
      </div>
      <button class="btn btn-primary" onclick="openAddVehicleModal()">+ Add Vehicle</button>
    </div>

    <!-- Add Vehicle Modal -->
    <div id="addVehicleModal" class="modal">
      <div class="modal-content">
        <div class="modal-header">
          <h2>Add Vehicle</h2>
          <button class="modal-close" onclick="closeAddVehicleModal()">&times;</button>
        </div>
        <form action="/add-vehicle" method="post" class="modal-form">
          <div class="group">
            <label for="number-plate">Number Plate</label>
            <input type="text" id="number-plate" name="number_plate" required />
          </div>

          <div class="group">
            <label for="model">Model</label>
            <input type="text" id="model" name="model" required />
          </div>

          <div class="group">
            <label for="color">Color</label>
            <input type="text" id="color" name="color" required />
          </div>

          <div class="group">
            <label for="capacity">Capacity (Seats)</label>
            <input type="number" id="capacity" name="capacity" min="1" required />
          </div>

          <div class="group">
            <label for="status">Status</label>
            <select id="status" name="status" required style="width: 100%; padding: 0.5rem; border: 1px solid var(--border-color); border-radius: var(--border-radius); font-size: 0.95rem;">
              <option value="active">Active</option>
              <option value="maintenance">Maintenance</option>
              <option value="retired">Retired</option>
            </select>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" onclick="closeAddVehicleModal()">Cancel</button>
            <button type="submit" class="btn btn-primary">Add Vehicle</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Change Vehicle Status Modal -->
    <div id="changeVehicleStatusModal" class="modal">
      <div class="modal-content">
        <div class="modal-header">
          <h2>Change Vehicle Status</h2>
          <button class="modal-close" onclick="closeChangeVehicleStatusModal()">&times;</button>
        </div>
        <div style="padding: var(--spacing-md);">
          <p style="margin-bottom: var(--spacing-md); color: var(--text-color);"><strong>Vehicle:</strong> <span id="vehicleInfo"></span></p>
          <div class="group">
            <label for="vehicle-new-status">New Status</label>
            <select id="vehicle-new-status" style="width: 100%; padding: 0.5rem; border: 1px solid var(--border-color); border-radius: var(--border-radius); font-size: 0.95rem;">
              <option value="active">Active</option>
              <option value="maintenance">Maintenance</option>
              <option value="retired">Retired</option>
            </select>
          </div>
          <div class="modal-footer" style="padding-top: var(--spacing-md);">
            <button type="button" class="btn btn-secondary" onclick="closeChangeVehicleStatusModal()">Cancel</button>
            <button type="button" class="btn btn-primary" onclick="submitVehicleStatusChange()">Update Status</button>
          </div>
        </div>
      </div>
    </div>

    <div class="dashboard-card">
      <h2>Vehicles List</h2>

      <div class="card-controls">
        <div class="search-box">
          <input type="text" placeholder="Search vehicles by plate or model..." />
        </div>
        <div class="filter-group">
          <select>
            <option>All Vehicles</option>
            <option>Active</option>
            <option>Maintenance</option>
            <option>Retired</option>
          </select>
        </div>
      </div>

      <div class="vehicles-list">
        <table class="routes-table">
          <thead>
            <tr>
              <th>Number Plate</th>
              <th>Model</th>
              <th>Color</th>
              <th>Capacity</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% vehicles.forEach(vehicle => { %>
              <tr>
                <td><%= vehicle.number_plate %></td>
                <td><%= vehicle.model %></td>
                <td><%= vehicle.color %></td>
                <td><%= vehicle.capacity %> seats</td>
                <td><span class="badge badge-<%= vehicle.status === 'active' ? 'success' : vehicle.status === 'maintenance' ? 'warning' : 'danger' %>"><%= vehicle.status %></span></td>
                <td><button class="btn btn-sm btn-secondary" onclick="openChangeVehicleStatusModal('<%= vehicle.number_plate %>', '<%= vehicle.model %>', '<%= vehicle.status %>')">Change Status</button></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<%- include('dashboard-footer') %>
