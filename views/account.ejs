<section class="section container">
    <div class="flex justify-between items-center mb-2">
        <h1>My Account</h1>
        <a href="/auth/logout" class="pure-button btn-outline">Log Out</a>
    </div>

    <div class="pure-g">
        <div class="pure-u-1 pure-u-md-1-3 mb-2">
            <div class="card text-center">
                <div class="user-pill mx-auto mb-1" style="width: 80px; height: 80px; font-size: 2rem;">
                    <%= user.first_name[0] %><%= user.last_name[0] %>
                </div>
                <h3><%= user.first_name %> <%= user.last_name %></h3>
                <p class="text-muted"><%= user.email %></p>
                <p class="badge badge-info mt-1"><%= (user.role || 'Member').toUpperCase() %></p>
            </div>
        </div>
        
        <div class="pure-u-1 pure-u-md-2-3">
            <div class="card">
                <h3>Recent Bookings</h3>
                <div class="mt-1">
                    <p class="text-muted">No travel bookings found in your history.</p>
                    <a href="/book" class="pure-button btn-primary mt-1">Book Your First Trip</a>
                </div>
                
                <h3 class="mt-4">Recent Parcels</h3>
                <div class="mt-1">
                    <p class="text-muted">No parcel deliveries found in your history.</p>
                    <a href="/parcel" class="pure-button btn-accent mt-1">Send a Parcel</a>
                </div>
            </div>
        </div>
    </div>
</section>
