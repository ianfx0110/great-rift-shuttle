<section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
        <span class="hero-badge fade-in">Kenya's #1 SACCO</span>
        <h1 class="fade-in">Connecting the Rift <br/>With Reliable Travel.</h1>
        <p class="fade-in mt-1">Daily passenger shuttles, secure parcel couriers, and heavy freight logistics across East Africa. Trusted since 2004.</p>
        <div class="hero-actions mt-2 fade-in">
            <a href="/book" class="pure-button btn-primary btn-large">Book a Trip</a>
            <a href="/parcel" class="pure-button btn-accent btn-large">Send a Parcel</a>
        </div>
    </div>
</section>

<section class="quick-widget section">
    <div class="container">
        <div class="card shadow-md">
            <div class="tabs-header mb-1">
                <button class="tab-btn active" onclick="switchTab('book')">Book Trip</button>
                <button class="tab-btn" onclick="switchTab('parcel')">Send Parcel</button>
                <button class="tab-btn" onclick="switchTab('track')">Track</button>
            </div>
            
            <div id="book-tab" class="tab-content active">
                <form action="/book" method="GET" class="pure-form pure-form-stacked">
                    <div class="pure-g">
                        <div class="pure-u-1 pure-u-md-1-4">
                            <label>From</label>
                            <select name="from" class="pure-input-1">
                                <option value="">Select Origin</option>
                                <% towns.forEach(t => { %>
                                    <option value="<%= t.name %>"><%= t.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="pure-u-1 pure-u-md-1-4">
                            <label>To</label>
                            <select name="to" class="pure-input-1">
                                <option value="">Select Destination</option>
                                <% towns.forEach(t => { %>
                                    <option value="<%= t.name %>"><%= t.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="pure-u-1 pure-u-md-1-4">
                            <label>Date</label>
                            <input type="date" name="date" class="pure-input-1" min="<%= new Date().toISOString().split('T')[0] %>">
                        </div>
                        <div class="pure-u-1 pure-u-md-1-4">
                            <label>&nbsp;</label>
                            <button type="submit" class="pure-button btn-primary pure-input-1">Search Trips</button>
                        </div>
                    </div>
                </form>
            </div>

            <div id="parcel-tab" class="tab-content">
                <form action="/parcel" method="GET" class="pure-form pure-form-stacked">
                    <div class="pure-g">
                        <div class="pure-u-1 pure-u-md-1-4">
                            <label>From</label>
                            <select name="from" class="pure-input-1">
                                <option value="">Select Origin</option>
                                <% towns.forEach(t => { %>
                                    <option value="<%= t.name %>"><%= t.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="pure-u-1 pure-u-md-1-4">
                            <label>To</label>
                            <select name="to" class="pure-input-1">
                                <option value="">Select Destination</option>
                                <% towns.forEach(t => { %>
                                    <option value="<%= t.name %>"><%= t.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="pure-u-1 pure-u-md-1-4">
                            <label>Weight (kg)</label>
                            <input type="number" name="weight" placeholder="e.g. 5" class="pure-input-1">
                        </div>
                        <div class="pure-u-1 pure-u-md-1-4">
                            <label>&nbsp;</label>
                            <button type="submit" class="pure-button btn-accent pure-input-1">Get Quote</button>
                        </div>
                    </div>
                </form>
            </div>

            <div id="track-tab" class="tab-content">
                <form action="/track" method="GET" class="pure-form pure-form-stacked">
                    <div class="pure-g">
                        <div class="pure-u-1 pure-u-md-3-4">
                            <label>Tracking Code</label>
                            <input type="text" name="code" placeholder="GR-XXXX-XXXX" class="pure-input-1">
                        </div>
                        <div class="pure-u-1 pure-u-md-1-4">
                            <label>&nbsp;</label>
                            <button type="submit" class="pure-button btn-primary pure-input-1">Track Now</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<section class="services-section section container">
    <div class="text-center mb-2">
        <h2 class="fade-in">Our Services</h2>
        <p class="fade-in text-muted">A comprehensive range of travel and logistics solutions adapted for you.</p>
    </div>
    
    <div class="pure-g">
        <div class="pure-u-1 pure-u-sm-1-2 pure-u-lg-1-4 mb-2 fade-in">
            <div class="card card-hover text-center h-full">
                <div class="service-icon"><i class="ti ti-bus"></i></div>
                <h3>Passenger Travel</h3>
                <p>Comfortable and safe trips across Kenya with our modern fleet of 14, 33, and 51 seaters.</p>
                <a href="/book" class="mt-1 inline-block font-bold">Book Now &rarr;</a>
            </div>
        </div>
        <div class="pure-u-1 pure-u-sm-1-2 pure-u-lg-1-4 mb-2 fade-in">
            <div class="card card-hover text-center h-full">
                <div class="service-icon"><i class="ti ti-package"></i></div>
                <h3>Parcel & Courier</h3>
                <p>Fast, reliable, and trackable delivery for your documents and small packages nationwide.</p>
                <a href="/parcel" class="mt-1 inline-block font-bold">Send Parcel &rarr;</a>
            </div>
        </div>
        <div class="pure-u-1 pure-u-sm-1-2 pure-u-lg-1-4 mb-2 fade-in">
            <div class="card card-hover text-center h-full">
                <div class="service-icon"><i class="ti ti-truck-delivery"></i></div>
                <h3>Freight Logistics</h3>
                <p>Heavy cargo and industrial move solutions with real-time tracking and logistics planning.</p>
                <a href="/freight" class="mt-1 inline-block font-bold">Get Quote &rarr;</a>
            </div>
        </div>
        <div class="pure-u-1 pure-u-sm-1-2 pure-u-lg-1-4 mb-2 fade-in">
            <div class="card card-hover text-center h-full">
                <div class="service-icon"><i class="ti ti-car-suv"></i></div>
                <h3>Charter Hire</h3>
                <p>Exclusive hire for events, schools, and corporate trips with professional drivers.</p>
                <a href="/charter" class="mt-1 inline-block font-bold">Request Charter &rarr;</a>
            </div>
        </div>
    </div>
</section>

<section class="popular-routes section container fade-in">
    <div class="flex justify-between items-center mb-2">
        <h3 class="text-xl font-bold border-l-4 border-[#D4A017] pl-3">Popular Daily Routes</h3>
        <div class="flex items-center gap-2">
            <span class="w-3 h-3 bg-[#27AE60] rounded-full animate-pulse"></span>
            <span class="text-xs font-bold text-[#6B6B6B]">LIVE DEPARTURES</span>
        </div>
    </div>
    
    <div class="pure-g">
        <% routes.forEach(r => { %>
            <div class="pure-u-1 pure-u-md-1-4 mb-2">
                <div class="bg-white p-5 rounded-xl border border-[#E0DDD6] shadow-sm hover:shadow-md transition-shadow h-full flex flex-col">
                    <div class="flex justify-between items-start mb-3">
                        <span class="bg-[#d4edda] text-[#155724] text-[10px] font-bold px-2 py-0.5 rounded">AVAILABLE</span>
                        <span class="text-xs font-bold text-[#1A4D2E]">KES <%= r.base_fare %></span>
                    </div>
                    <div class="text-sm font-bold text-[#1C1C1C] flex-1"><%= r.origin_name %> → <%= r.dest_name %></div>
                    <div class="text-[11px] text-[#6B6B6B] mt-1">Daily Shuttle · Fast & Secure</div>
                    <a href="/book?from=<%= r.origin_name %>&to=<%= r.dest_name %>" class="w-full mt-4 text-[#1A4D2E] border border-[#1A4D2E] py-2 rounded-lg text-xs font-bold hover:bg-[#1A4D2E] hover:text-white transition-colors text-center">Select Trip</a>
                </div>
            </div>
        <% }) %>
        
        <!-- M-Pesa Trust Block -->
        <div class="pure-u-1 pure-u-md-1-4 mb-2">
            <div class="bg-[#1A4D2E] p-5 rounded-xl flex flex-col items-center justify-center text-center h-full">
                <div class="w-12 h-12 bg-white rounded-full flex items-center justify-center mb-2 overflow-hidden">
                    <span class="text-[#27AE60] font-black text-xs">M-PESA</span>
                </div>
                <div class="text-white font-bold text-xs uppercase tracking-tight">Instant Payment</div>
                <p class="text-[#F2F0EB] text-[10px] mt-1 opacity-80">Secure Lipa na M-Pesa integration for all bookings.</p>
            </div>
        </div>
    </div>
</section>

<section class="live-ticker">
    <div class="ticker-label">NEWS FLASH</div>
    <div class="ticker-wrap">
        <div class="ticker">
            <% departures.forEach(d => { %>
                <span class="ticker-item">
                    ★ <%= d.departure_time %>: <%= d.origin_name %> to <%= d.dest_name %> - KES <%= d.fare %>
                </span>
            <% }) %>
        </div>
    </div>
</section>

<section class="why-us section container">
    <div class="text-center mb-2">
        <h2 class="fade-in">Why Choose Us?</h2>
    </div>
    <div class="pure-g">
        <div class="pure-u-1 pure-u-md-1-3 text-center mb-2 fade-in">
            <i class="ti ti-shield-check text-4xl text-primary mb-1"></i>
            <h4>Licensed SACCO</h4>
            <p>Fully compliant with NTSA regulations and SACCO laws for your peace of mind.</p>
        </div>
        <div class="pure-u-1 pure-u-md-1-3 text-center mb-2 fade-in">
            <i class="ti ti-device-mobile text-4xl text-primary mb-1"></i>
            <h4>M-Pesa Integrated</h4>
            <p>Book and pay instantly using M-Pesa. Receive your ticket via SMS and Email.</p>
        </div>
        <div class="pure-u-1 pure-u-md-1-3 text-center mb-2 fade-in">
            <i class="ti ti-map-pin text-4xl text-primary mb-1"></i>
            <h4>全国 Agents</h4>
            <p>Over 100 offices and agents across the country to serve you wherever you are.</p>
        </div>
    </div>
</section>

<section class="map-section section fade-in">
    <div class="container">
        <h2 class="text-center mb-2">Find Our Offices</h2>
        <div id="map" style="height: 450px; border-radius: var(--radius-lg); border: 1px solid var(--border);"></div>
    </div>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script>
    function switchTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        
        document.getElementById(tabId + '-tab').classList.add('active');
        event.currentTarget.classList.add('active');
    }

    // Leaflet Map
    var map = L.map('map').setView([0.0236, 37.9062], 6.5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    var agents = <%- JSON.stringify(towns) %>;
    agents.forEach(function(a) {
        if (a.lat && a.lng) {
            L.marker([a.lat, a.lng]).addTo(map)
                .bindPopup("<b>" + a.name + " Office</b><br>Great Rift Shuttle Agent");
        }
    });
</script>
