<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Home' }) %>
</head>
<body class="bg-bg text-text font-sans antialiased">
    <%- include('partials/nav') %>

    <!-- Hero Section -->
    <header class="relative pt-12 pb-24 overflow-hidden bg-bg border-b border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
          <div class="mb-12 lg:mb-0">
            <div class="inline-flex items-center space-x-2 bg-card px-3 py-1 rounded-full border border-border shadow-sm mb-6">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
              </span>
              <span class="text-primary font-black text-[10px] uppercase tracking-widest">System Online: Great Rift corridor</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-black text-primary leading-[1] mb-8 tracking-tighter">
              Premium <br/>
              Road Travel <br/>
              <span class="text-accent italic">Redefined.</span>
            </h1>
            <p class="text-lg text-slate-500 mb-10 max-w-md leading-relaxed font-medium">
              We operate the most punctual and secure shuttle network connecting Kenya's strategic urban hubs.
            </p>
            <div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-4">
              <a href="/booking" class="bg-primary text-white px-8 py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-blue-900 shadow-xl shadow-blue-900/20 transition-all flex items-center justify-center">
                Secure Seat <i data-lucide="chevron-right" class="ml-2 w-4 h-4"></i>
              </a>
              <a href="/parcel" class="bg-card text-primary border border-border px-8 py-4 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-bg transition-all shadow-sm flex items-center justify-center">
                Dispatch Cargo
              </a>
            </div>
          </div>
          <div class="relative">
            <div class="bg-card rounded-[2.5rem] p-4 border border-border shadow-2xl">
              <img src="https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?auto=format&fit=crop&q=80&w=1000" alt="Premium Shuttle" class="rounded-[2rem] w-full h-[480px] object-cover"/>
            </div>
            <!-- Floating Service Badge -->
            <div class="absolute -bottom-8 -right-8 bg-card p-6 rounded-3xl shadow-2xl border border-border max-w-[240px] transform hover:scale-105 transition-transform">
               <div class="bg-accent/10 w-10 h-10 rounded-xl flex items-center justify-center mb-4">
                  <i data-lucide="shield-check" class="text-accent w-6 h-6"></i>
               </div>
               <h4 class="font-black text-xs text-primary uppercase mb-1">Guaranteed Safety</h4>
               <p class="text-[10px] text-slate-400 font-bold leading-relaxed">24/7 Fleet command center monitoring every mile of your journey.</p>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Refined Search Form -->
    <section class="max-w-5xl mx-auto px-4 -mt-12 relative z-20">
      <div class="bg-card p-2 rounded-[2rem] shadow-2xl border border-border">
        <form action="/booking" method="GET" class="grid grid-cols-1 md:grid-cols-4 gap-2">
          <div class="p-4 bg-bg rounded-2xl flex flex-col justify-center border border-transparent hover:border-border transition-all">
            <label class="text-[9px] font-black text-slate-400 uppercase tracking-[0.2em] mb-1">Departure Point</label>
            <div class="relative">
              <select name="origin" class="w-full bg-transparent text-sm font-black text-primary outline-none appearance-none cursor-pointer uppercase italic">
                <option value="NAIROBI">Nairobi Hub</option>
                <option value="NAKURU">Nakuru Node</option>
                <option value="ELDORET">Eldoret Hub</option>
                <option value="KISUMU">Kisumu Node</option>
              </select>
            </div>
          </div>
          <div class="p-4 bg-bg rounded-2xl flex flex-col justify-center border border-transparent hover:border-border transition-all">
            <label class="text-[9px] font-black text-slate-400 uppercase tracking-[0.2em] mb-1">Arrival Hub</label>
            <div class="relative">
              <select name="destination" class="w-full bg-transparent text-sm font-black text-primary outline-none appearance-none cursor-pointer uppercase italic">
                <option value="ELDORET">Eldoret Hub</option>
                <option value="NAKURU" selected>Nakuru Node</option>
                <option value="NAIROBI">Nairobi Hub</option>
                <option value="KISUMU">Kisumu Node</option>
              </select>
            </div>
          </div>
          <div class="p-4 bg-bg rounded-2xl flex flex-col justify-center border border-transparent hover:border-border transition-all">
            <label class="text-[9px] font-black text-slate-400 uppercase tracking-[0.2em] mb-1">Travel Matrix</label>
            <input type="date" name="date" id="search-date" class="bg-transparent text-sm font-black text-primary outline-none cursor-pointer w-full uppercase" required />
          </div>
          <button type="submit" class="bg-accent text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-orange-600 transition-all shadow-xl shadow-orange-500/10 flex items-center justify-center p-4 italic">
            Inspect Availability <i data-lucide="radar" class="ml-2 w-4 h-4"></i>
          </button>
        </form>
      </div>
    </section>

    <!-- Popular Routes Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 space-y-6 md:space-y-0 text-center md:text-left">
        <div>
          <span class="text-accent font-black text-[10px] uppercase tracking-[3px] mb-2 block">Premium Connectivity</span>
          <h2 class="text-4xl font-black text-primary italic uppercase tracking-tighter">Recommended Routes</h2>
          <p class="text-xs text-slate-400 font-bold uppercase tracking-tight mt-1">The most popular connections in the region.</p>
        </div>
        <a href="/routes" class="flex items-center text-[10px] font-black text-primary border-b-2 border-accent pb-1 uppercase tracking-widest hover:text-accent transition-all group">
          View Logistics Map <i data-lucide="map" class="ml-2 w-4 h-4 group-hover:rotate-12 transition-transform"></i>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <% recommendedRoutes.forEach(route => { %>
          <div class="bg-card rounded-[2.5rem] border border-border p-10 hover:border-accent transition-all group relative overflow-hidden flex flex-col justify-between">
            <div class="absolute -right-8 -top-8 opacity-10 group-hover:opacity-20 transition-opacity">
              <i data-lucide="route" class="w-48 h-48 text-primary"></i>
            </div>
            <div>
              <div class="flex justify-between items-start mb-8">
                <div class="bg-accent/10 w-14 h-14 rounded-2xl flex items-center justify-center">
                  <i data-lucide="navigation" class="text-accent w-7 h-7"></i>
                </div>
                <span class="text-[10px] font-black text-slate-300 uppercase tracking-widest bg-slate-50 px-3 py-1 rounded-full border border-slate-100">Daily Service</span>
              </div>
              <h3 class="text-2xl font-black text-primary uppercase italic mb-2 tracking-tight"><%= route.destination %></h3>
              <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-6"><%= route.origin %> <i data-lucide="arrow-right" class="inline w-3 h-3 mx-2 text-accent"></i> <%= route.destination %></p>
              
              <div class="space-y-4 mb-8">
                <div class="flex items-center text-xs font-black text-primary uppercase">
                  <i data-lucide="clock" class="w-4 h-4 mr-3 text-accent"></i> <%= route.estimated_duration %> Duration
                </div>
                <div class="flex items-center text-xs font-black text-primary uppercase">
                  <i data-lucide="bus" class="w-4 h-4 mr-3 text-accent"></i> Premium Shuttle
                </div>
                <div class="flex items-center text-xs font-black text-primary uppercase">
                  <i data-lucide="shield-check" class="w-4 h-4 mr-3 text-accent"></i> Licensed Service
                </div>
              </div>
            </div>

            <div class="pt-8 border-t border-border flex justify-between items-center">
               <div>
                  <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Settlement Rate</p>
                  <p class="text-2xl font-black text-primary italic uppercase tracking-tighter">KES <%= (Math.floor(Math.random() * 700) + 800).toLocaleString() %></p>
               </div>
               <a href="/booking" class="bg-primary text-white w-12 h-12 rounded-2xl flex items-center justify-center hover:bg-accent transition-all shadow-lg group-hover:scale-110">
                  <i data-lucide="arrow-right" class="w-5 h-5"></i>
               </a>
            </div>
          </div>
        <% }) %>
      </div>
    </section>

    <!-- Operational Edge Section (Why Us) -->
    <section class="bg-primary py-24 relative overflow-hidden">
      <div class="absolute inset-0 opacity-5 pointer-events-none">
         <div class="grid grid-cols-6 h-full w-full">
            <div class="border-r border-white/20"></div>
            <div class="border-r border-white/20"></div>
            <div class="border-r border-white/20"></div>
            <div class="border-r border-white/20"></div>
            <div class="border-r border-white/20"></div>
            <div class="border-r border-white/20"></div>
         </div>
      </div>
      
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="lg:grid lg:grid-cols-2 gap-20 items-center">
          <div>
            <span class="text-accent font-black text-[10px] uppercase tracking-[3px] mb-4 block">Standard of Excellence</span>
            <h2 class="text-5xl font-black text-white italic uppercase tracking-tighter mb-8 leading-[1.1]">Elite Transport <br/>Infrastructure.</h2>
            <p class="text-lg text-blue-100 font-medium leading-relaxed mb-10">
              We don't just move passengers; we manage a high-precision logistics ecosystem designed for safety, speed, and absolute reliability.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
              <div class="flex items-start space-x-4">
                <div class="bg-blue-800 p-3 rounded-xl border border-white/10 shrink-0">
                  <i data-lucide="shield-check" class="text-accent w-6 h-6"></i>
                </div>
                <div>
                  <h4 class="text-sm font-black text-white uppercase italic tracking-wide">Guaranteed Safety</h4>
                  <p class="text-[10px] text-blue-200 uppercase tracking-widest mt-1">24/7 Fleet command center monitoring every mile.</p>
                </div>
              </div>
              <div class="flex items-start space-x-4">
                <div class="bg-blue-800 p-3 rounded-xl border border-white/10 shrink-0">
                  <i data-lucide="zap" class="text-accent w-6 h-6"></i>
                </div>
                <div>
                  <h4 class="text-sm font-black text-white uppercase italic tracking-wide">Rapid Deployment</h4>
                  <p class="text-[10px] text-blue-200 uppercase tracking-widest mt-1">Express nodes for expedited regional travel.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="mt-16 lg:mt-0 relative">
             <div class="grid grid-cols-2 gap-4">
                <div class="space-y-4 pt-12">
                   <div class="bg-blue-800/40 backdrop-blur-md p-1 rounded-[2rem] border border-white/10 shadow-2xl">
                      <img src="https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?auto=format&fit=crop&q=80&w=600" class="rounded-[1.8rem] w-full h-64 object-cover" alt="Fleet"/>
                   </div>
                   <div class="bg-accent p-8 rounded-[2rem] shadow-2xl">
                      <p class="text-white font-black text-4xl italic uppercase tracking-tighter">99.8%</p>
                      <p class="text-[10px] text-white/80 font-black uppercase tracking-widest mt-2">Punctuality Score</p>
                   </div>
                </div>
                <div class="space-y-4">
                   <div class="bg-blue-800/40 backdrop-blur-md p-8 rounded-[2rem] border border-white/10 shadow-2xl">
                      <p class="text-white font-black text-4xl italic uppercase tracking-tighter">150k+</p>
                      <p class="text-[10px] text-white/80 font-black uppercase tracking-widest mt-2">Corridor Missions</p>
                   </div>
                   <div class="bg-card/10 backdrop-blur-md p-1 rounded-[2rem] border border-white/5">
                      <img src="https://images.unsplash.com/photo-1570125909232-eb263c188f7e?auto=format&fit=crop&q=80&w=600" class="rounded-[1.8rem] w-full h-80 object-cover grayscale brightness-50" alt="Landscape"/>
                   </div>
                </div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Scale of Excellence Section -->
    <section class="max-w-7xl mx-auto px-4 py-24">
      <div class="bg-card border border-border rounded-[3.5rem] p-12 lg:p-24 shadow-sm flex flex-col lg:flex-row items-center justify-between space-y-12 lg:space-y-0">
        <div class="lg:max-w-md text-center lg:text-left">
          <h2 class="text-4xl font-black text-primary uppercase italic tracking-tighter mb-6 leading-[1.1]">The Regional Impact Matrix</h2>
          <p class="text-slate-400 text-sm font-medium leading-relaxed">Scaling Kenya's transport infrastructure through digitized manifests, secure settlement protocols, and a zero-latency fleet network.</p>
        </div>
        <div class="flex-1 grid grid-cols-2 lg:grid-cols-3 gap-12 lg:ml-24">
          <div class="text-center lg:text-left">
            <p class="text-5xl font-black text-accent italic tracking-tighter uppercase mb-2">12M+</p>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Kilometers Logged</p>
          </div>
          <div class="text-center lg:text-left">
            <p class="text-5xl font-black text-primary italic tracking-tighter uppercase mb-2">2x</p>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Fleet Expansion</p>
          </div>
          <div class="text-center lg:text-left">
            <p class="text-5xl font-black text-accent italic tracking-tighter uppercase mb-2">24/7</p>
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Live Surveillance</p>
          </div>
        </div>
      </div>
    </section>

    <!-- App Promo / Digital Gateway -->
    <section class="max-w-7xl mx-auto px-4 pb-24">
      <div class="bg-accent rounded-[3.5rem] p-12 lg:p-24 text-white flex flex-col lg:flex-row items-center justify-between relative overflow-hidden group">
        <div class="absolute right-0 bottom-0 opacity-10 -translate-y-1/4 translate-x-1/4 pointer-events-none group-hover:rotate-12 transition-transform duration-1000">
           <i data-lucide="smartphone" class="w-[500px] h-[500px]"></i>
        </div>
        <div class="relative z-10 lg:max-w-xl text-center lg:text-left">
          <span class="text-white font-black text-[10px] uppercase tracking-[3px] mb-4 block opacity-80">Digital Terminal Interface</span>
          <h2 class="text-5xl font-black uppercase italic tracking-tighter mb-6 leading-tight">Your Corridor Hub <br/>In Your Pocket</h2>
          <p class="text-white/80 text-lg font-bold leading-relaxed mb-10">Real-time GPS tracking, instant manifest verification, and automated M-Pesa settlement for the modern elite traveler.</p>
          
          <!-- App buttons removed as per request -->
        </div>
        <div class="hidden lg:block relative z-10 w-72 h-[480px] bg-primary rounded-[3rem] border-[12px] border-bg shadow-2xl overflow-hidden p-6">
           <div class="w-24 h-1 bg-slate-300 rounded-full mx-auto mb-10"></div>
           <div class="space-y-6">
              <div class="w-full h-12 bg-accent/20 rounded-2xl border border-white/10"></div>
              <div class="flex space-x-4">
                 <div class="flex-1 h-32 bg-white/5 rounded-2xl border border-white/5"></div>
                 <div class="flex-1 h-32 bg-white/5 rounded-2xl border border-white/5"></div>
              </div>
              <div class="w-full h-8 bg-accent/20 rounded-xl"></div>
              <div class="space-y-3 pt-6">
                 <div class="w-full h-3 bg-white/10 rounded-full"></div>
                 <div class="w-3/4 h-3 bg-white/10 rounded-full"></div>
                 <div class="w-1/2 h-3 bg-white/10 rounded-full"></div>
              </div>
           </div>
        </div>
      </div>
    </section>

    <%- include('partials/footer') %>

    <script>
      // Enforce temporal integrity (Future dates only)
      document.addEventListener('DOMContentLoaded', () => {
         const dateInput = document.getElementById('search-date');
         const now = new Date();
         const today = now.toISOString().split('T')[0];
         dateInput.min = today;
         dateInput.value = today;
         
         // Lucide update for injected icons
         if (window.lucide) {
           lucide.createIcons();
         }
      });
    </script>
</body>
</html>
