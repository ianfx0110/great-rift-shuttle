<section class="section container">
    <div class="text-center mb-2">
        <h1>Send a Parcel</h1>
        <p class="text-muted">Fast and reliable courier services across our network.</p>
    </div>

    <div class="max-w-3xl mx-auto">
        <div class="card shadow-md">
            <h3 class="mb-1">Calculate Quote</h3>
            <form id="parcelForm" class="pure-form pure-form-stacked">
                <div class="pure-g">
                    <div class="pure-u-1 pure-u-md-1-2">
                        <label>Origin</label>
                        <select id="p_from" required class="pure-input-1">
                            <option value="">Select Town</option>
                            <% towns.forEach(t => { %>
                                <option value="<%= t.id %>"><%= t.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="pure-u-1 pure-u-md-1-2">
                        <label>Destination</label>
                        <select id="p_to" required class="pure-input-1">
                            <option value="">Select Town</option>
                            <% towns.forEach(t => { %>
                                <option value="<%= t.id %>"><%= t.name %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="pure-g mt-1">
                    <div class="pure-u-1 pure-u-md-1-2">
                        <label>Weight (KG)</label>
                        <input type="number" id="p_weight" value="1" min="1" class="pure-input-1">
                    </div>
                    <div class="pure-u-1 pure-u-md-1-2">
                        <label>Size Category</label>
                        <select id="p_size" class="pure-input-1">
                            <option value="small">Small (Envelope/Small Box)</option>
                            <option value="medium">Medium (Standard Box)</option>
                            <option value="large">Large (Sack/Big Box)</option>
                            <option value="xlarge">Extra Large (Furniture/Engine)</option>
                        </select>
                    </div>
                </div>

                <div class="mt-2 p-2 bg-surface-alt border-radius-md flex justify-between items-center">
                    <div>
                        <p class="text-muted">Estimated Delivery Time:</p>
                        <p class="font-bold">Next Day (24-48 Hours)</p>
                    </div>
                    <div class="text-right">
                        <p class="text-muted">Estimated Fare:</p>
                        <p class="text-2xl font-bold text-primary" id="parcelQuote">KES 500</p>
                    </div>
                </div>

                <div class="mt-2 text-right">
                    <button type="submit" class="pure-button btn-primary">Proceed to Send &rarr;</button>
                </div>
            </form>
        </div>
    </div>
</section>

<script>
    const fromSelect = document.getElementById('p_from');
    const toSelect = document.getElementById('p_to');
    const weightInput = document.getElementById('p_weight');
    const sizeSelect = document.getElementById('p_size');
    const quoteEl = document.getElementById('parcelQuote');

    function updateQuote() {
        if (!fromSelect.value || !toSelect.value) return;
        let base = 300;
        let weight = parseFloat(weightInput.value);
        let sizeMultiplier = { small: 1, medium: 1.5, large: 2.5, xlarge: 5 }[sizeSelect.value];
        let total = Math.round((base + (weight * 20)) * sizeMultiplier);
        quoteEl.innerText = 'KES ' + total;
    }

    [fromSelect, toSelect, weightInput, sizeSelect].forEach(el => el.addEventListener('change', updateQuote));
    weightInput.addEventListener('input', updateQuote);

    document.getElementById('parcelForm').addEventListener('submit', (e) => {
        e.preventDefault();
        
        const from = fromSelect.options[fromSelect.selectedIndex].text;
        const to = toSelect.options[toSelect.selectedIndex].text;
        const weight = weightInput.value;
        const size = sizeSelect.options[sizeSelect.selectedIndex].text;
        const quote = quoteEl.innerText;

        let message = `*NEW PARCEL QUOTE REQUEST*\n\n`;
        message += `*Origin:* ${from}\n`;
        message += `*Destination:* ${to}\n`;
        message += `*Weight:* ${weight} KG\n`;
        message += `*Size:* ${size}\n`;
        message += `*Estimated Quote:* ${quote}\n\n`;
        message += `Please advise on branch drop-off and delivery timing.`;

        const encoded = encodeURIComponent(message);
        const whatsappUrl = `https://wa.me/254115481162?text=${encoded}`;
        
        window.showToast("Redirecting to WhatsApp...");
        setTimeout(() => {
            window.open(whatsappUrl, '_blank');
        }, 1000);
    });
</script>
