<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { title: 'Parcel Logistics' }) %>
</head>
<body class="bg-bg text-text font-sans antialiased">
    <%- include('partials/nav') %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end">
        <div>
          <h1 class="text-3xl font-black text-primary mb-2 uppercase italic tracking-tight">Logistics Command</h1>
          <p class="text-xs text-gray-400 font-bold uppercase tracking-[3px]">Consign parcels across the Great Rift network.</p>
        </div>
         <div class="mt-4 md:mt-0 flex space-x-4">
            <div class="bg-card px-4 py-2 rounded-xl border border-border shadow-sm flex items-center">
               <i data-lucide="package" class="w-4 h-4 mr-2 text-accent"></i>
               <span class="text-[10px] font-black text-primary uppercase">Safe Transit Guaranteed</span>
            </div>
         </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- New Consignment Form -->
        <div class="lg:col-span-2">
           <form id="parcel-form" class="bg-card p-8 rounded-3xl border border-border shadow-xl space-y-10">
              <!-- Sender & Receiver -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                 <div class="space-y-4">
                    <h4 class="text-[10px] font-black uppercase tracking-widest text-accent mb-4 border-b border-accent/10 pb-2">Sender Terminal</h4>
                    <div class="flex flex-col gap-1.5">
                       <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Full Legal Name</label>
                       <input type="text" id="s-name" required placeholder="Consignor Name" class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none"/>
                    </div>
                    <div class="flex flex-col gap-1.5">
                       <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Mobile Comm</label>
                       <input type="tel" id="s-phone" required placeholder="07XX XXX XXX" class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none"/>
                    </div>
                 </div>
                 <div class="space-y-4">
                    <h4 class="text-[10px] font-black uppercase tracking-widest text-primary mb-4 border-b border-primary/10 pb-2">Receiver Hub Access</h4>
                    <div class="flex flex-col gap-1.5">
                       <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Consignee Name</label>
                       <input type="text" id="r-name" required placeholder="Receiver Name" class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none"/>
                    </div>
                    <div class="flex flex-col gap-1.5">
                       <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Consignee Mobile</label>
                       <input type="tel" id="r-phone" required placeholder="07XX XXX XXX" class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none"/>
                    </div>
                 </div>
              </div>

              <!-- Logistics Detail -->
              <div class="space-y-6 pt-6 border-t border-border">
                 <h4 class="text-[10px] font-black uppercase tracking-widest text-slate-400">Consignment Data</h4>
                 <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-1.5">
                       <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Departure Hub</label>
                       <select id="origin-hub" class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none appearance-none"></select>
                    </div>
                    <div class="flex flex-col gap-1.5">
                       <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Arrival Hub</label>
                       <select id="dest-hub" class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none appearance-none"></select>
                    </div>
                 </div>
                 <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
                    <div class="flex flex-col gap-1.5">
                       <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Weight Class (KG)</label>
                       <input type="number" id="weight" step="0.1" value="1.0" class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none"/>
                    </div>
                    <div class="flex flex-col gap-2 pt-6">
                       <label class="flex items-center space-x-2 cursor-pointer">
                          <input type="checkbox" id="fragile" class="w-5 h-5 rounded border-border text-accent focus:ring-accent"/>
                          <span class="text-xs font-black uppercase tracking-tight text-primary italic">Fragile Cargo</span>
                       </label>
                    </div>
                 </div>
                 <div class="flex flex-col gap-1.5">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest pl-1">Consignment Description</label>
                    <textarea id="description" rows="3" placeholder="e.g. Sealed box containing legal documents..." class="w-full bg-bg border border-border rounded-xl px-4 py-3 text-sm font-semibold focus:ring-2 focus:ring-accent outline-none resize-none"></textarea>
                 </div>
              </div>

              <div class="flex flex-col md:flex-row justify-between items-center bg-bg p-6 rounded-2xl border border-border">
                 <div class="mb-4 md:mb-0">
                    <p class="text-[8px] font-black text-slate-400 uppercase tracking-widest mb-1">Logistics Carriage Fee</p>
                    <p class="text-3xl font-black text-primary italic uppercase tracking-tighter" id="calc-fee">KES 0</p>
                 </div>
                 <button type="submit" class="w-full md:w-auto bg-accent text-white px-10 py-4 rounded-xl font-black text-xs uppercase tracking-widest shadow-xl shadow-orange-500/10 hover:bg-orange-600 transition-all flex items-center justify-center">
                    Proceed to Dispatch <i data-lucide="send" class="ml-2 w-4 h-4"></i>
                 </button>
              </div>
           </form>
        </div>

        <!-- Sidebar Info -->
        <div class="space-y-6">
           <div class="bg-primary p-8 rounded-3xl text-white shadow-xl relative overflow-hidden">
              <div class="absolute -right-8 -top-8 w-32 h-32 bg-accent/20 rounded-full blur-2xl"></div>
              <h4 class="text-xs font-black uppercase tracking-widest text-accent mb-6">Network Policy</h4>
              <ul class="space-y-6 relative z-10">
                 <li class="flex items-start">
                    <div class="bg-accent/20 p-1.5 rounded-lg mr-4 mt-0.5"><i data-lucide="check" class="w-3 h-3 text-accent"></i></div>
                    <div>
                       <p class="text-[10px] font-black uppercase tracking-tight">Same-Day Transit</p>
                       <p class="text-[10px] text-blue-200 mt-1">Parcels booked before 10 AM arrive at destination hub same day.</p>
                    </div>
                 </li>
                 <li class="flex items-start">
                    <div class="bg-accent/20 p-1.5 rounded-lg mr-4 mt-0.5"><i data-lucide="check" class="w-3 h-3 text-accent"></i></div>
                    <div>
                       <p class="text-[10px] font-black uppercase tracking-tight">SMS Real-Time Sync</p>
                       <p class="text-[10px] text-blue-200 mt-1">Automatic alerts sent to consignee upon arrival and collection.</p>
                    </div>
                 </li>
              </ul>
           </div>

           <div class="bg-card border border-border p-6 rounded-3xl shadow-sm">
               <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-4">Calculate Rate</p>
               <div class="flex items-center justify-between text-xs font-bold text-primary mb-2">
                  <span>Base Rate</span>
                  <span>KES 300</span>
               </div>
               <div class="flex items-center justify-between text-xs font-bold text-primary mb-4 pb-4 border-b border-border">
                  <span>Per KG Charge</span>
                  <span>KES 50</span>
               </div>
               <p class="text-[8px] text-slate-400 leading-relaxed italic">*Fragile cargo incurs a flat KES 100 handling fee for premium casing.</p>
           </div>
        </div>
      </div>
    </main>

    <%- include('partials/footer') %>

    <script type="module">
      import { api, setupAuth } from '/src/main.js';
      setupAuth();

      const user = JSON.parse(localStorage.getItem('user')) || {};
      const parcelForm = document.getElementById('parcel-form');
      const originSelect = document.getElementById('origin-hub');
      const destSelect = document.getElementById('dest-hub');
      const weightInput = document.getElementById('weight');
      const fragileInput = document.getElementById('fragile');
      const feeDisplay = document.getElementById('calc-fee');

      if (user.id) {
         document.getElementById('s-name').value = user.name || '';
         document.getElementById('s-phone').value = user.phone || '';
      }

      function calculateFee() {
         const weight = parseFloat(weightInput.value) || 0;
         const fragile = fragileInput.checked;
         let fee = 300 + (weight * 50);
         if (fragile) fee += 100;
         feeDisplay.textContent = `KES ${Math.round(fee)}`;
         return Math.round(fee);
      }

      [weightInput, fragileInput].forEach(el => el.addEventListener('input', calculateFee));

      async function loadHubs() {
         const hubs = await api.get('/api/hubs');
         const html = hubs.map(h => `<option value="${h.id}">${h.name}</option>`).join('');
         originSelect.innerHTML = html;
         destSelect.innerHTML = html;
         calculateFee();
      }

      parcelForm.onsubmit = async (e) => {
         e.preventDefault();
         const fee = calculateFee();
         const senderPhone = document.getElementById('s-phone').value;
         
         const payload = {
            senderId: user.id || null,
            senderName: document.getElementById('s-name').value,
            senderPhone: senderPhone,
            senderEmail: user.email || '',
            receiverName: document.getElementById('r-name').value,
            receiverPhone: document.getElementById('r-phone').value,
            originHubId: originSelect.value,
            destinationHubId: destSelect.value,
            description: document.getElementById('description').value,
            weight: parseFloat(weightInput.value),
            fee: fee,
            isFragile: fragileInput.checked
         };

         const submitBtn = parcelForm.querySelector('button[type="submit"]');
         try {
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white mr-2"></div> Consigning...`;
            
            const res = await api.post('/api/parcels', payload);
            alert(`Consignment Confirmed!\nTracking Number: ${res.trackingNumber}\nCheck phone for M-Pesa STK push.`);
            window.location.href = `/tracking?number=${res.trackingNumber}`;
         } catch (error) {
            alert('Consignment failed: ' + error.message);
         } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = `Proceed to Dispatch <i data-lucide="send" class="ml-2 w-4 h-4"></i>`;
            lucide.createIcons();
         }
      };

      loadHubs();
    </script>
</body>
</html>
