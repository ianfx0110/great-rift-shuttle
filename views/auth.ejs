<section class="auth-section section container">
    <div class="auth-grid">
        <div class="auth-card card">
            <div class="auth-tabs mb-2">
                <button class="auth-tab-btn active" onclick="switchAuthTab('login')">Login</button>
                <button class="auth-tab-btn" onclick="switchAuthTab('register')">Register</button>
            </div>

            <div id="login-form" class="auth-form active">
                <h2 class="mb-1">Welcome Back</h2>
                <form action="/auth/login" method="POST" class="pure-form pure-form-stacked">
                    <label>Email Address</label>
                    <input type="email" name="email" required class="pure-input-1">
                    
                    <label>Password</label>
                    <input type="password" name="password" required class="pure-input-1">
                    
                    <div class="flex justify-between items-center mt-1 mb-1">
                        <label class="pure-checkbox">
                            <input type="checkbox"> Remember me
                        </label>
                        <a href="/auth/forgot-password" class="text-sm">Forgot Password?</a>
                    </div>
                    
                    <button type="submit" class="pure-button btn-primary pure-input-1">Login to Account</button>
                </form>
            </div>

            <div id="register-form" class="auth-form">
                <h2 class="mb-1">Join Great Rift Shuttle</h2>
                <form action="/auth/register" method="POST" class="pure-form pure-form-stacked">
                    <div class="pure-g">
                        <div class="pure-u-1 pure-u-md-1-2">
                            <label>First Name</label>
                            <input type="text" name="first_name" required class="pure-input-1">
                        </div>
                        <div class="pure-u-1 pure-u-md-1-2">
                            <label>Last Name</label>
                            <input type="text" name="last_name" required class="pure-input-1">
                        </div>
                    </div>
                    
                    <label>Email Address</label>
                    <input type="email" name="email" required class="pure-input-1">
                    
                    <label>Phone Number</label>
                    <input type="tel" name="phone" required placeholder="07XXXXXXXX" class="pure-input-1">
                    
                    <label>Password</label>
                    <input type="password" name="password" required class="pure-input-1">
                    
                    <p class="text-xs text-muted mb-1 mt-1">By registering, you agree to our Terms and Privacy Policy.</p>
                    
                    <button type="submit" class="pure-button btn-primary pure-input-1">Create Account</button>
                </form>
            </div>
        </div>
    </div>
</section>

<script>
    function switchAuthTab(type) {
        document.querySelectorAll('.auth-form').forEach(f => f.classList.remove('active'));
        document.querySelectorAll('.auth-tab-btn').forEach(b => b.classList.remove('active'));
        
        document.getElementById(type + '-form').classList.add('active');
        event.currentTarget.classList.add('active');
    }
</script>
